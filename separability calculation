def ee_getinfo_retry(obj, retries=6, base_delay=8.0):
    """指数退避重试，最多 6 次（8→16→32→64→120→120s）。"""
    last = None
    for i in range(retries):
        try:
            return obj.getInfo()
        except Exception as e:
            last = e
            wait = min(base_delay * (2 ** i), 120.0)
            print("  [retry %d/%d] %.0fs — %s" % (i+1, retries, wait, repr(e)))
            time.sleep(wait)
    raise last


