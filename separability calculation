def write_csv(path, rows, columns):
    import csv
    with open(path,"w",newline="",encoding="utf-8-sig") as fh:
        w=csv.DictWriter(fh,fieldnames=columns); w.writeheader()
        for r in rows: w.writerow(r)
    print("[csv] wrote:", path)


