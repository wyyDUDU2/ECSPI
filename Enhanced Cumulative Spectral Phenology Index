// E1: Fig.5 — 分类别箱线图（CandlestickChart 近似 Boxplot）
// ═══════════════════════════════════════════════════════════════════════
evalBoxplotBtn.onClick(function() {
    var cspList = [];
    if (globalCache.CSP_s2only) cspList.push({img: globalCache.CSP_s2only, band: 'CSP_s2only', label: 'CSP_S2'});
    if (globalCache.CSP_fused)  cspList.push({img: globalCache.CSP_fused,  band: 'CSP_fused',  label: 'ECSPI'});
    
    if (cspList.length === 0) {
        evalStatus.setValue('ERROR: Run M1 or M2 first to get CSP!');
        return;
    }
    
    evalStatus.setValue('Sampling CSP values by crop type...');
    
    // 棉花样本加 cropType=1
    var cottonWithType = cottonSamplesRaw.map(function(f) { return f.set('cropType', 1); });
    var allWithType = cottonWithType.merge(otherSamplesRaw);
    
    for (var ci = 0; ci < cspList.length; ci++) {
        (function(cIdx) {
            var cspImg = cspList[cIdx].img;
            var bandName = cspList[cIdx].band;
            var chartLabel = cspList[cIdx].label;
            
            var sampled = cspImg.rename('csp_val').unmask(0).sampleRegions({
                collection: allWithType,
                properties: ['cropType'],
                scale: outputScale,
                tileScale: tileScale,
                geometries: false
            });
            
            // 按类别分别提取值
            var cropGroups = [
                {cropType: 1, name: 'Cotton'},
                {cropType: 2, name: 'Corn'},
                {cropType: 3, name: 'Wheat'},
                {cropType: 6, name: 'Others'}  // NonCrop + Orchard + OtherCrop 合并为Others
            ];
            
            // 把 cropType 4,5 也归入 Others
            var othersFC = sampled.filter(
                ee.Filter.or(
                    ee.Filter.eq('cropType', 4),
                    ee.Filter.eq('cropType', 5),
                    ee.Filter.eq('cropType', 6)
                )
            );
            
            var groupFCs = {
                1: sampled.filter(ee.Filter.eq('cropType', 1)),
                2: sampled.filter(ee.Filter.eq('cropType', 2)),
                3: sampled.filter(ee.Filter.eq('cropType', 3)),
                6: othersFC
            };
            
            var totalGroups = cropGroups.length;
            var completedGroups = 0;
            var groupVals = {};
            
            for (var gi = 0; gi < cropGroups.length; gi++) {
                (function(gIdx) {
                    var grp = cropGroups[gIdx];
                    var fc = groupFCs[grp.cropType];
                    
                    fc.aggregate_array('csp_val').evaluate(function(vals, err) {
                        if (err) vals = [];
                        groupVals[grp.cropType] = vals;
                        completedGroups++;
                        
                        if (completedGroups < totalGroups) return;
                        
                       // 全部取完，构建频次直方图
                        var allVals = [];
                        for (var k = 0; k < cropGroups.length; k++) {
                            allVals = allVals.concat(groupVals[cropGroups[k].cropType]);
                        }
                        if (allVals.length === 0) {
                            evalStatus.setValue('No data sampled');
                            return;
                        }
                        
                        var globalMin = Math.min.apply(null, allVals);
                        var globalMax = Math.max.apply(null, allVals);
                        var nBins = 50;
                        var binWidth = (globalMax - globalMin) / nBins;
                        if (binWidth <= 0) { evalStatus.setValue('Zero range'); return; }
                        
                        // 初始化各类别直方图
                        var hists = {};
                        var means = {};
                        var counts = {};
                        for (var h = 0; h < cropGroups.length; h++) {
                            var ct = cropGroups[h].cropType;
                            hists[ct] = zeroArray(nBins);
                            var vArr = groupVals[ct];
                            counts[ct] = vArr.length;
                            var sum = 0;
                            for (var v = 0; v < vArr.length; v++) {
                                sum += vArr[v];
                                var idx = Math.min(Math.floor((vArr[v] - globalMin) / binWidth), nBins - 1);
                                if (idx >= 0) hists[ct][idx]++;
                            }
                            means[ct] = vArr.length > 0 ? sum / vArr.length : 0;
                        }
                        
                        // 构建图表数据
                        var rows = [['CSP', 'Cotton', 'Corn', 'Wheat', 'Others']];
                        for (var b = 0; b < nBins; b++) {
                            var binCenter = globalMin + (b + 0.5) * binWidth;
                            rows.push([
                                binCenter,
                                hists[1][b],
                                hists[2][b],
                                hists[3][b],
                                hists[6][b]
                            ]);
                        }
                        
                        // 标注文本：均值 + 样本量
                        var annotationText = 
                            'Cotton: μ=' + safeToFixed(means[1], 3) + ' (n=' + counts[1] + ')' +
                            '    Corn: μ=' + safeToFixed(means[2], 3) + ' (n=' + counts[2] + ')' +
                            '    Wheat: μ=' + safeToFixed(means[3], 3) + ' (n=' + counts[3] + ')' +
                            '    Others: μ=' + safeToFixed(means[6], 3) + ' (n=' + counts[6] + ')';
                        
                        var chart = ui.Chart(rows, 'AreaChart', {
    title: chartLabel + ' Distribution by Crop Type — ' + currentRegion.toUpperCase() + ' ' + yearSelect.getValue() + '\n' + annotationText,
    titleTextStyle: {fontSize: 20, bold: true},
    hAxis: {
        title: 'CSP',
        titleTextStyle: {fontSize: 22, bold: true, italic: false},
        textStyle: {fontSize: 18},
        gridlines: {color: '#E0E0E0', count: 10}
    },
    vAxis: {
        title: 'Count',
