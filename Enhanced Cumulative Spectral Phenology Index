        m3_rfModel = null;
        m3_completedBatches = [];
        m3_batchCounts = [];
        globalCache.result_m3 = null;
        
        m3Status.setValue('Features ready (' + bands.length + ' bands)');
        globalStatusLabel.setValue('M3 Step 2: Complete (' + bands.length + ' features)');
        print('M3 feature bands :', bands);
    });
});


