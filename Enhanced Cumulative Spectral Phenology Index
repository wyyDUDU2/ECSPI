m2Step4Btn.onClick(function() {
    if (!globalCache.T1_image || !globalCache.CSP_s2only) {
        m2Status.setValue('ERROR: Run Step 2.3 first!');
        return;
    }
    
    if (globalCache.CSP_modis) {
        m2Status.setValue('MODIS CSP cached, verifying...');
        globalCache.CSP_modis.bandNames().evaluate(function(bands, error) {
            if (error) {
                m2Status.setValue('Cache invalid, recomputing...');
                globalCache.CSP_modis = null;
                return;
            }
            m2Status.setValue('MODIS CSP cached (verified)');
            globalStatusLabel.setValue('M2 Step 4: Using cache');
        });
        return;
    }
    
    m2Status.setValue('Processing MODIS...');
    globalStatusLabel.setValue('M2: Processing MODIS data...');
    
    var modisProcessed = globalCache.modis.map(processModis);
    var modisMedian = modisProcessed.median();
    
    var startDateEE = globalCache.startDateEE;
    var periodSeq = globalCache.periodSeq;
    
    var modisComposites = ee.ImageCollection.fromImages(
        periodSeq.map(function(periodIndex) {
            periodIndex = ee.Number(periodIndex);
            var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
            var periodEnd = periodStart.advance(compositePeriod, 'day');
            var midDate = periodStart.advance(compositePeriod / 2, 'day');
            var doy = midDate.getRelative('day', 'year');
            var modisFiltered = modisProcessed.filterDate(
                periodStart.advance(-8, 'day'),
                periodEnd.advance(8, 'day')
            );
            var modisComposite = ee.Algorithms.If(
                modisFiltered.size().gt(0),
                modisFiltered.median().float(),
                modisMedian.float()
            );
            return ee.Image(modisComposite).float()
                .set('system:time_start', midDate.millis())
                .set('DOY', doy)
                .set('period_index', periodIndex);
        })
    );
    
    var modisNDVISeries = modisComposites.map(function(image) {
        return image.select('MODIS_NDVI').float().rename('modis_val')
            .copyProperties(image, ['system:time_start', 'DOY', 'period_index']);
    });
    
    var s2SISeries = globalCache.filledSIComposites.map(function(image) {
        return image.select('SI_filled').float().rename('s2_val')
            .copyProperties(image, ['system:time_start', 'DOY', 'period_index']);
    });
    
    m2Status.setValue('Removing outliers & normalizing...');
    
   // ── MODIS CSP: use NDVI directly with independent T1/T2 ──
    // NO min-max normalization here — Step 2.6 z-score handles scale alignment
    
   // ── MODIS CSP: 线性回归将NDVI映射到S2 SI值域 ──
    // 物理依据：NDVI与SI都反映植被状态，但量纲不同
    // 在耕地区域拟合 SI = a×NDVI + b，使MODIS CSP与S2 CSP直接可比
    var s2SIMedian = globalCache.filledSIComposites.select('SI_filled').median()
        .updateMask(comprehensiveMask);
    var modisNDVIMedian = modisComposites.select('MODIS_NDVI').median()
        .updateMask(comprehensiveMask);
    
    var regressionInput = ee.Image.cat([
        modisNDVIMedian.rename('x'),
        s2SIMedian.rename('y')
    ]);
    var regressionResult = regressionInput.reduceRegion({
        reducer: ee.Reducer.linearFit(),
        geometry: studyArea,
        scale: 250,
        maxPixels: 1e13,
        bestEffort: true,
        tileScale: 8
    });
    
    var scaleFactor = ee.Number(regressionResult.get('scale'));
    var offsetFactor = ee.Number(regressionResult.get('offset'));
    
    var modisSI = modisComposites.map(function(image) {
        var ndvi = image.select('MODIS_NDVI').float();
        var siMapped = ndvi.multiply(scaleFactor).add(offsetFactor)
            .float().rename('SI_filled');
        return siMapped.copyProperties(image, ['system:time_start', 'DOY', 'period_index']);
    });
    
    
    m2Status.setValue('Smoothing MODIS SI & detecting MODIS T1/T2...');
    
    var smoothedModisSI = smoothTimeSeriesPixelWise(modisSI, 'SI_filled', sgHalfWindow);
    
    // 固定模式：MODIS也用相同的固定T1/T2，跳过检测
    if (m2PhenoStrategy === 'fixed') {
        globalCache.T1_modis = globalCache.T1_image;
        globalCache.T2_modis = globalCache.T2_image;
    } else {
        var T1T2_modis = detectPerPixelT1T2(
