            padLeft(String(overallResult.n1), 9) + ' | ' +
            padLeft(String(overallResult.n2), 7) + ' | ' +
            padLeft(safeToFixed(overallResult.mu1, 4), 8) + ' | ' +
            padLeft(safeToFixed(overallResult.mu2, 4), 8) + ' | ' +
            padLeft(safeToFixed(overallResult.M, 2), 6) + ' | ' +
            safeToFixed(overallResult.JM, 2) + '\n';

        // 分类别行
        for (var i = 0; i < subResults.length; i++) {
            var r = subResults[i];
            if (!r) continue;
            txt += padRight('vs ' + r.name, 20) + '| ' +
                padLeft(String(overallResult.n1), 9) + ' | ' +
                padLeft(String(r.nSub), 7) + ' | ' +
                padLeft(safeToFixed(overallResult.mu1, 4), 8) + ' | ' +
                padLeft(safeToFixed(r.muSub, 4), 8) + ' | ' +
                padLeft(safeToFixed(r.M, 2), 6) + ' | ' +
                safeToFixed(r.JM, 2) + '\n';
        }
        print(txt);

        // 柱状图
        var chartRows = [['Comparison', 'M', 'JM']];
        chartRows.push(['All Noncotton', overallResult.M, overallResult.JM]);
        for (var j = 0; j < subResults.length; j++) {
            if (subResults[j]) {
                chartRows.push([subResults[j].name, subResults[j].M, subResults[j].JM]);
            }
        }
        var chart = ui.Chart(chartRows, 'ColumnChart', {
            title: 'CSP Separability: Cotton vs Each Class (' + label + ')',
            hAxis: {title: ''},
            vAxis: {title: 'Value', minValue: 0},
            colors: ['#E53935', '#1E88E5'],
            legend: {position: 'top'},
            bar: {groupWidth: '60%'}
        });
        print(chart);
    }

    // ── C: 执行整体分离度 ──
    mu1.evaluate(function(m1) {
        mu2.evaluate(function(m2) {
            n1.evaluate(function(c1) {
                n2.evaluate(function(c2) {
                    sep.M.evaluate(function(mVal) {
                        sep.JM.evaluate(function(jmVal) {
                            overallResult = {n1: c1, n2: c2, mu1: m1, mu2: m2, M: mVal, JM: jmVal};
                            tryPrintTable();
                        });
                    });
                });
            });
        });
    });

    // ── D: 执行分类别分离度 ──
    for (var si = 0; si < subCategories.length; si++) {
        (function(idx) {
            var cat = subCategories[idx];
            var subFC = otherSamplesFC.filter(ee.Filter.eq('cropType', cat.cropType));

            // 检查该类别是否有样本
            subFC.size().evaluate(function(subSize, sizeErr) {
                if (sizeErr || subSize === 0) {
                    subResults[idx] = null;
                    tryPrintTable();
                    return;
                }

                var subSep = computeSeparability(cspImage, bandName, cottonSamplesFC, subFC);
                var subCSP = cspImage.sampleRegions({
                    collection: subFC, properties: ['class'],
                    scale: outputScale, tileScale: tileScale
                });
                var muSub = ee.Number(subCSP.aggregate_mean(bandName));

                muSub.evaluate(function(muSubVal) {
                    subSep.M.evaluate(function(subM) {
                        subSep.JM.evaluate(function(subJM) {
                            subResults[idx] = {
                                name: cat.name,
                                nSub: subSize,
                                muSub: muSubVal,
                                M: subM,
                                JM: subJM
                            };
                            tryPrintTable();
                        });
                    });
                });
            });
        })(si);
    }
}


