// E2: Table4 — CSP_S2 vs ECSPI 分类别分离度对比表
//   输出: 完整的 M-index / JM-distance 对比表
//   Cotton vs {All, Corn, Wheat, Orchard, OtherCrop, NonCrop}
// ═══════════════════════════════════════════════════════════════════════
evalSepTableBtn.onClick(function() {
    if (!globalCache.CSP_s2only) {
        evalStatus.setValue('ERROR: Run M1 to get CSP_S2!');
        return;
    }
    
    var cspM1 = globalCache.CSP_s2only_m1 || globalCache.CSP_s2only;
    var cspM2 = globalCache.CSP_fused_m2  || globalCache.CSP_fused;
    
    if (!cspM1) {
        evalStatus.setValue('ERROR: Run M1 to get CSP_S2!');
        return;
    }
    var indexList = [{img: cspM1, band: 'CSP_s2only', label: 'CSP_S2'}];
    if (cspM2) {
        indexList.push({img: cspM2, band: 'CSP_fused', label: 'ECSPI'});
    }
    
    evalStatus.setValue('Computing separability table...');
    
    var subCategories = [
        {name: 'ALL Noncotton', fc: otherSamples},
        {name: 'Corn',          fc: otherSamplesRaw.filter(ee.Filter.eq('cropType', 2)).map(function(f){return f.set('class',0);})},
        {name: 'Wheat',         fc: otherSamplesRaw.filter(ee.Filter.eq('cropType', 3)).map(function(f){return f.set('class',0);})},
        {name: 'Orchard',       fc: otherSamplesRaw.filter(ee.Filter.eq('cropType', 4)).map(function(f){return f.set('class',0);})},
        {name: 'OtherCrop',     fc: otherSamplesRaw.filter(ee.Filter.eq('cropType', 5)).map(function(f){return f.set('class',0);})},
        {name: 'NonCrop',       fc: otherSamplesRaw.filter(ee.Filter.eq('cropType', 6)).map(function(f){return f.set('class',0);})}
    ];
    
    // 总任务数 = indexList.length × subCategories.length × 2(M+JM)
    var totalTasks = indexList.length * subCategories.length * 2;
    var completedTasks = 0;
    
    // results[indexIdx][subIdx] = {M: val, JM: val}
    var results = [];
    for (var ii = 0; ii < indexList.length; ii++) {
        results.push([]);
        for (var si = 0; si < subCategories.length; si++) {
            results[ii].push({M: null, JM: null});
        }
    }
    
    function tryPrintFullTable() {
        completedTasks++;
        if (completedTasks < totalTasks) return;
        
        // ── 构建完整对比表 ──
        var txt = '\n';
        txt += '═══════════════════════════════════════════════════════════════\n';
        txt += '  Table 4: Separability — Cotton vs Each Class\n';
        txt += '═══════════════════════════════════════════════════════════════\n';
        
        // 表头
        txt += padRight('Comparison', 18) + '|';
        for (var hi = 0; hi < indexList.length; hi++) {
            txt += padLeft(indexList[hi].label + ' M', 10) + ' |';
            txt += padLeft(indexList[hi].label + ' JM', 10) + ' |';
        }
        if (indexList.length === 2) {
            txt += padLeft('ΔM', 8) + ' |';
            txt += padLeft('ΔJM', 8) + ' |';
        }
        txt += '\n';
        
        // 分隔线
        txt += '------------------|';
        for (var di = 0; di < indexList.length; di++) {
            txt += '-----------|-----------|';
        }
        if (indexList.length === 2) {
            txt += '---------|---------|';
        }
        txt += '\n';
        
        // 数据行
        for (var ri = 0; ri < subCategories.length; ri++) {
            txt += padRight('vs ' + subCategories[ri].name, 18) + '|';
            for (var ci = 0; ci < indexList.length; ci++) {
                txt += padLeft(safeToFixed(results[ci][ri].M, 4), 10) + ' |';
                txt += padLeft(safeToFixed(results[ci][ri].JM, 4), 10) + ' |';
            }
            if (indexList.length === 2) {
                var deltaM = (results[1][ri].M !== null && results[0][ri].M !== null)
                    ? results[1][ri].M - results[0][ri].M : null;
                var deltaJM = (results[1][ri].JM !== null && results[0][ri].JM !== null)
                    ? results[1][ri].JM - results[0][ri].JM : null;
                
                var deltaMStr = deltaM !== null 
                    ? (deltaM >= 0 ? '+' : '') + safeToFixed(deltaM, 4) 
                    : 'N/A';
                var deltaJMStr = deltaJM !== null 
                    ? (deltaJM >= 0 ? '+' : '') + safeToFixed(deltaJM, 4) 
                    : 'N/A';
                
                txt += padLeft(deltaMStr, 8) + ' |';
                txt += padLeft(deltaJMStr, 8) + ' |';
            }
            txt += '\n';
        }
        txt += '═══════════════════════════════════════════════════════════════\n';
        
        print(txt);
        evalResults.setValue(txt);
        evalStatus.setValue('Separability table complete');
        
        // ── 柱状图: M-index 对比 ──
        var chartHeader = ['Comparison'];
        for (var ch = 0; ch < indexList.length; ch++) {
            chartHeader.push(indexList[ch].label + ' M-index');
            chartHeader.push(indexList[ch].label + ' JM-dist');
        }
        var chartRows = [chartHeader];
        for (var cr = 0; cr < subCategories.length; cr++) {
            var chartRow = [subCategories[cr].name];
            for (var cc = 0; cc < indexList.length; cc++) {
                chartRow.push(results[cc][cr].M || 0);
                chartRow.push(results[cc][cr].JM || 0);
            }
            chartRows.push(chartRow);
        }
        
        var colors = indexList.length === 2 
            ? ['#E53935', '#FFCDD2', '#1E88E5', '#BBDEFB']
            : ['#E53935', '#FFCDD2'];
        
        var chart = ui.Chart(chartRows, 'ColumnChart', {
            title: 'Separability: Cotton vs Each Class',
            titleTextStyle: {fontSize: 16, bold: true},
            hAxis: {title: '', textStyle: {fontSize: 12}},
            vAxis: {title: 'Value', minValue: 0, textStyle: {fontSize: 12}},
            colors: colors,
            legend: {position: 'top', textStyle: {fontSize: 12}},
            bar: {groupWidth: '70%'},
            chartArea: {left: 80, top: 60, width: '70%', height: '60%'},
            width: 800,
            height: 450
        });
        print(chart);
    }
    
    // ── 触发所有分离度计算 ──
    for (var iIdx = 0; iIdx < indexList.length; iIdx++) {
        for (var sIdx = 0; sIdx < subCategories.length; sIdx++) {
            (function(indexI, subI) {
                var subFC = subCategories[subI].fc;
                
                // 检查子类是否有样本
                subFC.size().evaluate(function(sz, szErr) {
                    if (szErr || sz === 0) {
                        results[indexI][subI] = {M: null, JM: null};
                        
                        tryPrintFullTable();
                        tryPrintFullTable();
                        return;
                    }
                    
                    var sep = computeSeparability(
                        indexList[indexI].img, indexList[indexI].band,
                        cottonSamples, subFC
                    );
                    
                    sep.M.evaluate(function(mVal) {
                        results[indexI][subI].M = mVal;
                        tryPrintFullTable();
                    });
                    sep.JM.evaluate(function(jmVal) {
                        results[indexI][subI].JM = jmVal;
                        tryPrintFullTable();
                    });
                });
            })(iIdx, sIdx);
        }
    }
});





