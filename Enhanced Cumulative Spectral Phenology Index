// ─── 3.3c: Classify (tiled to avoid capacity exceeded) ─────────────────────
//
// 核心思路: 将研究区分成 nCols×nRows 个子区域逐块分类，
// 每块独立 classify → 最后 mosaic。
// 这样每次GEE只需展开 55条计算链 在一个小区域上，不会超限。

m3Step3cBtn.onClick(function() {
    if (!m3_rfModel) {
        m3Status.setValue('ERROR: Run Step 3.3b first!');
        return;
    }
    if (!m3_features) {
        m3Status.setValue('ERROR: Features missing!');
        return;
    }
    
    m3Status.setValue('Classifying in tiles...');
    globalStatusLabel.setValue('M3: Tiled classification...');
    
    var nCols = 4;
    var nRows = 3;
    var nTiles = nCols * nRows;
    
    var coords = ee.List(studyArea.bounds().coordinates().get(0));
    
    coords.evaluate(function(coordsList, coordsErr) {
        if (coordsErr) {
            m3Status.setValue('ERROR: Bounds failed - ' + coordsErr);
            return;
        }
        
        var xMin = coordsList[0][0];
        var yMin = coordsList[0][1];
        var xMax = coordsList[2][0];
        var yMax = coordsList[2][1];
        var dx = (xMax - xMin) / nCols;
        var dy = (yMax - yMin) / nRows;
        
        var tiles = [];
        for (var r = 0; r < nRows; r++) {
            for (var c = 0; c < nCols; c++) {
                tiles.push(ee.Geometry.Rectangle([
                    xMin + c * dx, yMin + r * dy,
                    xMin + (c + 1) * dx, yMin + (r + 1) * dy
                ]));
            }
        }
        
        var rfMultiFeatureBands = [
            'NDVI_mean', 'NDVI_min', 'NDVI_max', 'NDVI_stdDev',
            'EVI_mean',  'EVI_min',  'EVI_max',  'EVI_stdDev',
            'LSWI_mean', 'LSWI_min', 'LSWI_max', 'LSWI_stdDev',
            'NDWI_mean', 'NDWI_min', 'NDWI_max', 'NDWI_stdDev',
            'BSI_mean',  'BSI_min',  'BSI_max',  'BSI_stdDev',
            'NDVI_T1', 'NDVI_T2', 'NDVI_valT1', 'NDVI_valT2', 'NDVI_amp', 'NDVI_dur', 'NDVI_rate',
            'EVI_T1',  'EVI_T2',  'EVI_valT1',  'EVI_valT2',  'EVI_amp',  'EVI_dur',  'EVI_rate',
            'LSWI_T1', 'LSWI_T2', 'LSWI_valT1', 'LSWI_valT2', 'LSWI_amp', 'LSWI_dur', 'LSWI_rate',
            'NDWI_T1', 'NDWI_T2', 'NDWI_valT1', 'NDWI_valT2', 'NDWI_amp', 'NDWI_dur', 'NDWI_rate',
            'BSI_T1',  'BSI_T2',  'BSI_valT1',  'BSI_valT2',  'BSI_amp',  'BSI_dur',  'BSI_rate'
        ];
        
        // 逐块分类（服务端拼接，不逐块evaluate）
        var tileImages = [];
        for (var t = 0; t < nTiles; t++) {
            var tileFeatures = m3_features.select(rfMultiFeatureBands).clip(tiles[t]);
            var tileResult = tileFeatures.classify(m3_rfModel).rename('RF_multiFeature');
            tileImages.push(tileResult.clip(tiles[t]));
        }
        
        var rfResult = ee.ImageCollection.fromImages(tileImages).mosaic()
            .rename('RF_multiFeature');
        
        var rfMasked = rfResult.eq(1).selfMask()
            .updateMask(comprehensiveMask)
            .clip(studyArea);
        
        if (usePostProcessing) {
            var kernel = ee.Kernel.circle({radius: 1, units: 'pixels'});
            rfMasked = rfMasked
                .unmask(0)
                .focal_max({kernel: kernel, iterations: 1})
                .focal_min({kernel: kernel, iterations: 1})
                .updateMask(comprehensiveMask)
                .selfMask()
                .rename('RF_multiFeature');
        }
        
        rfMasked.bandNames().evaluate(function(bands, error) {
            if (error) {
                m3Status.setValue('ERROR: Classification failed - ' + error);
                globalStatusLabel.setValue('M3 Step 3c: FAILED');
                globalCache.result_m3 = null;
                return;
            }
            
            globalCache.result_m3 = rfMasked;
            m3Status.setValue('Classification ready (' + nTiles + ' tiles, 55 features)');
            globalStatusLabel.setValue('M3 Step 3c: Complete');
            
            var yr = parseInt(yearSelect.getValue());
            updateMap(yr, globalCache.result_m3, 'M3: RF Multi-Feature', 'FF00FF');
        });
    });
});


