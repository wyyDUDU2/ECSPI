// ─── E7: Binary Classification Map (Cotton=green, NonCotton=gray) ──────────
// 不使用耕地掩膜，整个研究区显示：分类区域内 cotton=绿 / non-cotton=灰，
// 分类区域外保持透明（由分类结果自身的mask决定）
evalBinaryBtn.onClick(function() {
    var methods = [];
    if (globalCache.result_m1) methods.push({img: globalCache.result_m1, label: 'M1', color: 'FF0000'});
    if (globalCache.result_m2) methods.push({img: globalCache.result_m2, label: 'M2', color: 'FFFF00'});
    if (globalCache.result_m3) methods.push({img: globalCache.result_m3, label: 'M3', color: 'FF00FF'});
    if (globalCache.result_m4) methods.push({img: globalCache.result_m4, label: 'M4', color: '00FFFF'});
    
    if (methods.length === 0) {
        evalStatus.setValue('ERROR: Run at least one classification first!');
        return;
    }
    
    evalStatus.setValue('Rendering binary maps...');
    
    var yr = parseInt(yearSelect.getValue());
    var peakStart = yr + '-07-01';
    var peakEnd = yr + '-08-31';
    var s2Peak = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
        .filterBounds(studyArea)
        .filterDate(peakStart, peakEnd)
        .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 30))
        .map(maskS2Clouds);
    var fccComposite = s2Peak.median().clip(studyArea);
    
    Map.addLayer(fccComposite, {
        bands: ['B8', 'B4', 'B3'],
        min: 0.0, max: 0.4, gamma: 1.2
    }, 'FCC Background', true, 0.7);
    
    for (var i = 0; i < methods.length; i++) {
        var cottonBinary = methods[i].img.unmask(0).clip(studyArea);
        
        // 非棉花=深灰(#A0A0A0)，棉花=该方法对应颜色
        Map.addLayer(cottonBinary, {
            min: 0, max: 1,
            palette: ['A0A0A0', methods[i].color]
        }, 'Binary ' + methods[i].label, i === methods.length - 1);
    }
    
    evalStatus.setValue(methods.length + ' binary maps added');
    evalResults.setValue('DarkGray=Non-cotton\nM1=Red, M2=Yellow, M3=Purple, M4=Cyan\nMethods: ' +
        methods.map(function(m) { return m.label; }).join(', '));
