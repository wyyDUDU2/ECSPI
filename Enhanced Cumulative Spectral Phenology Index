            var cumRain = img.select('period_rain');
            var maxDaily = img.select('max_daily_rain');
            
            // 可信 = 累积降雨 < 阈值 AND 单日最大 < 暴雨阈值
            var reliable = cumRain.lt(threshImage)
                .and(maxDaily.lt(heavyRainImage))
                .rename('reliable').byte();
            
            return reliable
                .copyProperties(img, ['system:time_start', 'DOY', 'period_index']);
        });
        
        
        
        var removedCount = qualityMask.map(function(img) {
    return ee.Image.constant(1).subtract(img.select('reliable')).rename('removed');
}).sum();
var totalPeriodsEE = qualityMask.size();
var tooManyRemoved = removedCount.gt(ee.Image.constant(totalPeriodsEE).multiply(0.5));

qualityMask = qualityMask.map(function(img) {
    var restored = img.select('reliable').where(tooManyRemoved, 1).rename('reliable').byte();
    return restored.copyProperties(img, ['system:time_start', 'DOY', 'period_index']);
});



        globalCache.rainQualityMask = qualityMask;
        globalCache.rainThreshold = adaptiveThreshold;
        
        // 统计保留比例
        var reliableCounts = qualityMask.select('reliable').sum();
        var totalPeriods = qualityMask.size();
        
        reliableCounts.reduceRegion({
            reducer: ee.Reducer.mean(),
            geometry: studyArea,
            scale: 5000,
            bestEffort: true
        }).evaluate(function(maskStats) {
            totalPeriods.evaluate(function(nPeriods) {
                var meanReliable = maskStats ? maskStats['reliable'] : null;
                var retainPct = meanReliable !== null ? 
                    (meanReliable / nPeriods * 100).toFixed(1) : 'N/A';
                var removePct = meanReliable !== null ? 
                    ((1 - meanReliable / nPeriods) * 100).toFixed(1) : 'N/A';
                
