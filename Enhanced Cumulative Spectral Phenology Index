m4Step6Btn.onClick(function() {
    if (!m4_rfModel) {
        m4Status.setValue('ERROR: Run Step 4.5 first!');
        return;
    }
    if (!m4_features) {
        m4Status.setValue('ERROR: Features missing!');
        return;
    }
    
    m4Status.setValue('Classifying in tiles (12 features)...');
    globalStatusLabel.setValue('M4: Tiled classification...');
    
    var nCols = 3;
    var nRows = 2;
    var nTiles = nCols * nRows;
    
    var coords = ee.List(studyArea.bounds().coordinates().get(0));
    
    coords.evaluate(function(coordsList, coordsErr) {
        if (coordsErr) {
            m4Status.setValue('ERROR: Bounds failed - ' + coordsErr);
            return;
        }
        
        var xMin = coordsList[0][0];
        var yMin = coordsList[0][1];
        var xMax = coordsList[2][0];
        var yMax = coordsList[2][1];
        var dx = (xMax - xMin) / nCols;
        var dy = (yMax - yMin) / nRows;
        
        var tiles = [];
        for (var r = 0; r < nRows; r++) {
            for (var c = 0; c < nCols; c++) {
                tiles.push(ee.Geometry.Rectangle([
                    xMin + c * dx, yMin + r * dy,
                    xMin + (c + 1) * dx, yMin + (r + 1) * dy
                ]));
            }
        }
        
        var rfBands = [
        'NDVI_S2_mean', 'NDVI_S2_min', 'NDVI_S2_max', 'NDVI_S2_stdDev',
        'NDVI_S2_valT1', 'NDVI_S2_valT2', 'NDVI_S2_rate',
        'CSP_fused',
        'SI_T1', 'SI_T2', 'slope', 'cumulative_SI'
    ];
        
        var tileImages = [];
        for (var t = 0; t < nTiles; t++) {
            var tileFeatures = m4_features.select(rfBands).clip(tiles[t]);
            var tileResult = tileFeatures.classify(m4_rfModel).rename('RF_CSP_NDVI');
            tileImages.push(tileResult.clip(tiles[t]));
        }
        
        var rfResult = ee.ImageCollection.fromImages(tileImages).mosaic()
            .rename('RF_CSP_NDVI');
        
        var rfMasked = rfResult.eq(1).selfMask()
            .updateMask(comprehensiveMask)
            .clip(studyArea);
        
        if (usePostProcessing) {
            var kernel = ee.Kernel.circle({radius: 1, units: 'pixels'});
            rfMasked = rfMasked
                .unmask(0)
                .focal_max({kernel: kernel, iterations: 1})
                .focal_min({kernel: kernel, iterations: 1})
                .updateMask(comprehensiveMask)
                .selfMask()
                .rename('RF_CSP_NDVI');
        }
        
        rfMasked.bandNames().evaluate(function(bands, error) {
            if (error) {
                m4Status.setValue('ERROR: Classification failed - ' + error);
                globalStatusLabel.setValue('M4 Step 6: FAILED');
                globalCache.result_m4 = null;
                return;
            }
            
            globalCache.result_m4 = rfMasked;
            m4Status.setValue('Classification ready (' + nTiles + ' tiles, 12 features)');
            globalStatusLabel.setValue('M4 Step 6: Complete');
            
            var yr = parseInt(yearSelect.getValue());
            updateMap(yr, globalCache.result_m4, 'M4: RF CSP+NDVI', '00FFFF');
        });
    });
});

