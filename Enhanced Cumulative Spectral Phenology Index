        reducer: ee.Reducer.mean(),
        geometry: studyArea,
        scale: 5000,
        bestEffort: true,
        tileScale: tileScale
    });
    
    percentileStats.evaluate(function(pStats, error) {
        if (error) {
            rainStatus.setValue('ERROR: Percentile failed - ' + error);
            globalStatusLabel.setValue('R2: FAILED');
            return;
        }
        
        var p25 = pStats['period_rain_p25'] || 0;
        var p50 = pStats['period_rain_p50'] || 3;
        var p75 = pStats['period_rain_p75'] || 5;
        var p90 = pStats['period_rain_p90'] || 10;
        
        // 自适应阈值 = max(物理下限, P85)
        var physicalFloor = 10.0;
        var adaptiveThreshold = Math.max(physicalFloor, (p75 + p90) / 2);
        var heavyRainDaily = 20.0;
        
        var threshImage = ee.Image.constant(adaptiveThreshold).float();
        var heavyRainImage = ee.Image.constant(heavyRainDaily).float();
        
