function onMapClick(coords) {
    if (!globalCache.filledSIComposites || !globalCache.s2WithAllIndices || !globalCache.doyList) {
        return;
    }
    
    chartPanel.style().set('shown', true);
    chartPanel.clear();
    chartPanel.add(ui.Label('Loading time series...', {fontSize: '11px'}));
    
    var point = ee.Geometry.Point([coords.lon, coords.lat]);
    var startDateEE = globalCache.startDateEE;
    var periodSeq = globalCache.periodSeq;
    
    // Extract SI time series
    var siSeries = globalCache.filledSIComposites.map(function(img) {
        return img.select('SI_filled').set('system:time_start', img.get('system:time_start'));
    });
    
    // Build NDVI composites matching same periods
    var ndviSeries = ee.ImageCollection.fromImages(periodSeq.map(function(periodIndex) {
        periodIndex = ee.Number(periodIndex);
        var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
        var periodEnd = periodStart.advance(compositePeriod, 'day');
        var midDate = periodStart.advance(compositePeriod / 2, 'day');
        var periodImages = globalCache.s2WithAllIndices.filterDate(periodStart, periodEnd).select('NDVI');
        var composite = ee.Algorithms.If(
            periodImages.size().gt(0),
            periodImages.median().float(),
            ee.Image.constant(0).float().rename('NDVI').updateMask(ee.Image.constant(0))
        );
        return ee.Image(composite).set('system:time_start', midDate.millis());
    }));
    
    // Extract pixel values
    var siAtPoint = siSeries.map(function(img) {
        var val = img.reduceRegion({
            reducer: ee.Reducer.first(), geometry: point, scale: outputScale
        });
        var doy = ee.Date(img.get('system:time_start')).getRelative('day', 'year');
        return ee.Feature(null, {DOY: doy, SI: val.get('SI_filled')});
    });
    
    var ndviAtPoint = ndviSeries.map(function(img) {
        var val = img.reduceRegion({
            reducer: ee.Reducer.first(), geometry: point, scale: outputScale
        });
        var doy = ee.Date(img.get('system:time_start')).getRelative('day', 'year');
        return ee.Feature(null, {DOY: doy, NDVI: val.get('NDVI')});
    });
    
    // Get T1/T2 at this pixel
    var t1t2Dict = null;
    if (globalCache.T1_image && globalCache.T2_image) {
        t1t2Dict = ee.Image.cat([globalCache.T1_image, globalCache.T2_image]).reduceRegion({
            reducer: ee.Reducer.first(), geometry: point, scale: outputScale
        });
    }
    
    // Build charts
    var siFC = ee.FeatureCollection(siAtPoint);
    var ndviFC = ee.FeatureCollection(ndviAtPoint);
    
    siFC.aggregate_array('DOY').evaluate(function(doys, err) {
        if (err) { chartPanel.clear(); chartPanel.add(ui.Label('Error: ' + err)); return; }
        
        siFC.aggregate_array('SI').evaluate(function(siVals) {
            ndviFC.aggregate_array('NDVI').evaluate(function(ndviVals) {
                
                var fetchT1T2 = t1t2Dict ? t1t2Dict : ee.Dictionary({T1_DOY: T1_DOY_default, T2_DOY: T2_DOY_default});
                
                ee.Dictionary(fetchT1T2).evaluate(function(t1t2, t1t2err) {
                    chartPanel.clear();
                    
                    var t1Doy = (t1t2 && t1t2.T1_DOY) ? t1t2.T1_DOY : T1_DOY_default;
                    var t2Doy = (t1t2 && t1t2.T2_DOY) ? t1t2.T2_DOY : T2_DOY_default;
                    
                    chartPanel.add(ui.Label(
                        'Pixel: ' + coords.lon.toFixed(4) + ', ' + coords.lat.toFixed(4) +
                        '  T1=' + Math.round(t1Doy) + '  T2=' + Math.round(t2Doy),
                        {fontSize: '10px', fontWeight: 'bold', margin: '2px'}
                    ));
                    
                    // Build DataTable for SI
                    var siRows = [];
                    for (var i = 0; i < doys.length; i++) {
                        if (siVals[i] !== null && siVals[i] !== undefined) {
                            siRows.push([doys[i], siVals[i], null]);
                        }
                    }
                    // Add T1/T2 markers - interpolate SI value at T1 and T2
                    var siT1Val = null, siT2Val = null;
                    for (var j = 0; j < doys.length - 1; j++) {
                        if (siVals[j] !== null && siVals[j+1] !== null) {
                            if (doys[j] <= t1Doy && doys[j+1] >= t1Doy) {
                                var frac1 = (t1Doy - doys[j]) / (doys[j+1] - doys[j]);
                                siT1Val = siVals[j] + frac1 * (siVals[j+1] - siVals[j]);
                            }
                            if (doys[j] <= t2Doy && doys[j+1] >= t2Doy) {
                                var frac2 = (t2Doy - doys[j]) / (doys[j+1] - doys[j]);
                                siT2Val = siVals[j] + frac2 * (siVals[j+1] - siVals[j]);
                            }
                        }
                    }
                    if (siT1Val !== null) siRows.push([t1Doy, null, siT1Val]);
                    if (siT2Val !== null) siRows.push([t2Doy, null, siT2Val]);
                    siRows.sort(function(a, b) { return a[0] - b[0]; });
                    
                    var siDataTable = [['DOY', 'SI', 'T1/T2']].concat(siRows);
                    
                    var siChart = ui.Chart(siDataTable, 'LineChart', {
                        title: 'SI Time Series',
                        hAxis: {title: 'DOY'},
                        vAxis: {title: 'SI'},
                        series: {
                            0: {lineWidth: 2, color: 'blue'},
                            1: {lineWidth: 0, pointSize: 8, color: 'red', pointShape: 'diamond'}
                        },
                        legend: {position: 'bottom'},
                        height: 130
                    });
                    chartPanel.add(siChart);
                    
                    // Build DataTable for NDVI
                    var ndviRows = [];
                    for (var k = 0; k < doys.length; k++) {
                        if (ndviVals[k] !== null && ndviVals[k] !== undefined) {
                            ndviRows.push([doys[k], ndviVals[k], null]);
                        }
                    }
                    var ndviT1Val = null, ndviT2Val = null;
                    for (var m = 0; m < doys.length - 1; m++) {
                        if (ndviVals[m] !== null && ndviVals[m+1] !== null) {
                            if (doys[m] <= t1Doy && doys[m+1] >= t1Doy) {
                                var f1 = (t1Doy - doys[m]) / (doys[m+1] - doys[m]);
                                ndviT1Val = ndviVals[m] + f1 * (ndviVals[m+1] - ndviVals[m]);
                            }
                            if (doys[m] <= t2Doy && doys[m+1] >= t2Doy) {
                                var f2 = (t2Doy - doys[m]) / (doys[m+1] - doys[m]);
                                ndviT2Val = ndviVals[m] + f2 * (ndviVals[m+1] - ndviVals[m]);
                            }
                        }
                    }
                    if (ndviT1Val !== null) ndviRows.push([t1Doy, null, ndviT1Val]);
                    if (ndviT2Val !== null) ndviRows.push([t2Doy, null, ndviT2Val]);
                    ndviRows.sort(function(a, b) { return a[0] - b[0]; });
                    
                    var ndviDataTable = [['DOY', 'NDVI', 'T1/T2']].concat(ndviRows);
                    
                    var ndviChart = ui.Chart(ndviDataTable, 'LineChart', {
                        title: 'NDVI Time Series',
                        hAxis: {title: 'DOY'},
                        vAxis: {title: 'NDVI'},
                        series: {
                            0: {lineWidth: 2, color: 'green'},
                            1: {lineWidth: 0, pointSize: 8, color: 'red', pointShape: 'diamond'}
                        },
                        legend: {position: 'bottom'},
                        height: 130
                    });
                    chartPanel.add(ndviChart);
                    
                    var closeBtn = ui.Button({label: 'Close', onClick: function() {
                        chartPanel.style().set('shown', false);
                    }, style: {stretch: 'horizontal', fontSize: '10px'}});
                    chartPanel.add(closeBtn);
                });
            });
        });
    });
}

