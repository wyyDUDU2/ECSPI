// ── 4.4: 一次采样全部12 bands（计算图可控，无需JOIN） ──
m4Step5a1Btn.onClick(function() {
    if (!m4_features) { m4Status.setValue('ERROR: Run Step 4.3 first!'); return; }
    
    if (m4_trainData) {
        m4_trainData.size().evaluate(function(c, e) {
            if (e) { m4_trainData = null; m4Status.setValue('Cache invalid'); return; }
            m4Status.setValue('All features sampled (' + c + ' pts, 12 bands)');
            globalStatusLabel.setValue('M4 4.4: Using cache → skip to 4.7');
        });
        return;
    }
    
    var rfBands = [
        'NDVI_S2_mean', 'NDVI_S2_min', 'NDVI_S2_max', 'NDVI_S2_stdDev',
        'NDVI_S2_valT1', 'NDVI_S2_valT2', 'NDVI_S2_rate',
        'CSP_fused',
        'SI_T1', 'SI_T2', 'slope', 'cumulative_SI'
    ];
    
    m4Status.setValue('Sampling ALL 12 bands (extendedMask coverage)...');
    globalStatusLabel.setValue('M4 4.4: Full sampling...');
    
    var featureImage = m4_features.select(rfBands);
    var nBatches = 8;
    var withBatch = trainingSamples.randomColumn('_m4batch', 5555);
    var batchFCs = [];
    
    for (var b = 0; b < nBatches; b++) {
        var batchFilter;
        if (b === 0) {
            batchFilter = ee.Filter.lt('_m4batch', 1.0 / nBatches);
        } else if (b === nBatches - 1) {
            batchFilter = ee.Filter.gte('_m4batch', b / nBatches);
        } else {
            batchFilter = ee.Filter.and(
                ee.Filter.gte('_m4batch', b / nBatches),
                ee.Filter.lt('_m4batch', (b + 1) / nBatches)
            );
        }
        
        batchFCs.push(
            featureImage.sampleRegions({
                collection: withBatch.filter(batchFilter),
                properties: ['class'],
                scale: outputScale,
                tileScale: 16,
                geometries: false
            })
        );
    }
    
    var merged = batchFCs[0];
    for (var i = 1; i < batchFCs.length; i++) {
        merged = merged.merge(batchFCs[i]);
    }
    
    // ★ 诊断：检查特征值分布，验证非棉花样本是否有真实值
    merged.size().evaluate(function(count, error) {
        if (error) {
            m4Status.setValue('ERROR: Sampling failed - ' + error);
            globalStatusLabel.setValue('M4 4.4: FAILED');
            return;
        }
        m4_trainData = merged;
        
        // 诊断打印：检查 CSP_fused 在两类中的分布
        var cottonTrain = merged.filter(ee.Filter.eq('class', 1));
        var nonCottonTrain = merged.filter(ee.Filter.eq('class', 0));
        
        // 检查非棉花样本中 CSP_fused=0 的比例
        var zeroCSP = nonCottonTrain.filter(ee.Filter.eq('CSP_fused', 0));
        zeroCSP.size().evaluate(function(zeroCount) {
            nonCottonTrain.size().evaluate(function(ncCount) {
                var pctZero = ncCount > 0 ? (zeroCount / ncCount * 100).toFixed(1) : 'N/A';
                m4Status.setValue('Sampled: ' + count + ' pts × 12 bands');
                m4Results.setValue(
                    'Training data: ' + count + ' pts\n' +
                    'Non-cotton with CSP=0: ' + zeroCount + '/' + ncCount + 
                    ' (' + pctZero + '%)' +
                    '\n(Should be <10% with extendedMask)'
                );
                globalStatusLabel.setValue('M4 4.4: Complete');
            });
        });
    });
});



