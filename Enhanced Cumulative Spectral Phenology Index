        globalStatusLabel.setValue('M4 Step 2: Complete (' + bands.length + ' bands)');
    });
});



m4Step4Btn.onClick(function() {
    if (!m4_ndviStats) {
        m4Status.setValue('ERROR: Run Step 4.2 first!');
        return;
    }
    if (!globalCache.CSP_fused) {
        m4Status.setValue('ERROR: Need CSP_fused from M2!');
        return;
    }
    
    if (m4_features) {
        m4Status.setValue('Features cached, verifying...');
        m4_features.bandNames().evaluate(function(bands, error) {
            if (error) { m4_features = null; m4Status.setValue('Cache invalid'); return; }
            m4Status.setValue('Features cached (' + bands.length + ' bands)');
            globalStatusLabel.setValue('M4 Step 4: Using cache');
        });
        return;
    }
    
    // 检查 CSP 中间量所需的前置数据
    if (!globalCache.filledSIComposites || !globalCache.T1_image || !globalCache.T2_image) {
        m4Status.setValue('ERROR: Need base data + T1/T2 (run M2 steps 1-3)!');
        return;
    }
    
    m4Status.setValue('Computing CSP intermediates (SI_T1, SI_T2, slope, cumSI)...');
    globalStatusLabel.setValue('M4: CSP intermediates + combining features...');
    
    // 计算 CSP 中间量（4 bands）
    var cspFull = computePerPixelCSPFull(
        globalCache.filledSIComposites,
        globalCache.T1_image, globalCache.T2_image,
        globalCache.doyList, extendedMask
    ).clip(studyArea);
    
    // 合并全部 12 特征:
    //   m4_ndviStats: 7 bands (mean, min, max, stdDev, valT1, valT2, rate)
    //   CSP_fused:    1 band
    //   CSP 中间量:    4 bands (SI_T1, SI_T2, slope, cumulative_SI)

var cspFusedFilled = globalCache.CSP_fused
    .unmask(
        globalCache.CSP_fused.focal_mean({
            radius: 5,
            kernelType: 'circle',
            units: 'pixels',
            iterations: 3
        })
    )
    .rename('CSP_fused');

// CSP 中间量填充空值
var si_T1_filled = cspFull.select('SI_T1')
    .unmask(cspFull.select('SI_T1').focal_mean({radius: 3, kernelType: 'circle', units: 'pixels', iterations: 2}));
var si_T2_filled = cspFull.select('SI_T2')
    .unmask(cspFull.select('SI_T2').focal_mean({radius: 3, kernelType: 'circle', units: 'pixels', iterations: 2}));
var slope_filled = cspFull.select('slope')
    .unmask(cspFull.select('slope').focal_mean({radius: 3, kernelType: 'circle', units: 'pixels', iterations: 2}));
var cumSI_filled = cspFull.select('cumulative_SI')
    .unmask(cspFull.select('cumulative_SI').focal_mean({radius: 3, kernelType: 'circle', units: 'pixels', iterations: 2}));

var combinedFeatures = ee.Image.cat([
    m4_ndviStats,
    cspFusedFilled,
    si_T1_filled.rename('SI_T1'),
    si_T2_filled.rename('SI_T2'),
    slope_filled.rename('slope'),
    cumSI_filled.rename('cumulative_SI')
]).float().clip(studyArea);
    
    combinedFeatures.bandNames().evaluate(function(bands, error) {
        if (error) {
            m4Status.setValue('ERROR: Combine failed - ' + error);
            m4_features = null;
            return;
        }
        m4_features = combinedFeatures;
        // 清除下游
        m4_trainData = null;
        m4_rfModel = null;
        globalCache.result_m4 = null;
        
        m4Status.setValue('Features ready (' + bands.length + ' bands)');
        m4Results.setValue('Feature bands:\n' + bands.join('\n'));
        globalStatusLabel.setValue('M4 Step 4: Complete (' + bands.length + ')');
    });
});



