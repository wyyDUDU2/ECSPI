//15: BASE DATA COMPUTATION
function computeBaseData(yr, progressCallback) {
    progressCallback('Loading Sentinel-2...');
    
    var dynamicStartDate = yr + '-04-01';
    var dynamicEndDate = yr + '-10-31';
    var startDateEE = ee.Date(dynamicStartDate);
    var endDateEE = ee.Date(dynamicEndDate);
    
    var totalDays = endDateEE.difference(startDateEE, 'day');
    var numPeriods = totalDays.divide(compositePeriod).ceil();
    var periodSeq = ee.List.sequence(0, numPeriods.subtract(1));
    
    var sentinel2 = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
        .filterBounds(studyArea)
        .filterDate(dynamicStartDate, dynamicEndDate)
        .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 70));
    
    progressCallback('Loading MODIS...');
    var modis = ee.ImageCollection('MODIS/061/MOD13Q1')
        .filterBounds(studyArea)
        .filterDate(ee.Date(dynamicStartDate).advance(-16, 'day'), 
                    ee.Date(dynamicEndDate).advance(16, 'day'));
    
    progressCallback('Cloud masking...');
    var s2Masked = sentinel2.map(maskS2Clouds);
    
    progressCallback('Calculating indices...');
    var s2WithSI = s2Masked.map(calculateSI);
    var s2WithAllIndices = s2Masked.map(addAllIndices);
    
    progressCallback('Creating composites...');
    var siCompositesList = periodSeq.map(function(periodIndex) {
        periodIndex = ee.Number(periodIndex);
        var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
        var periodEnd = periodStart.advance(compositePeriod, 'day');
        var midDate = periodStart.advance(compositePeriod / 2, 'day');
        var doy = midDate.getRelative('day', 'year');
        var periodImages = s2WithSI.filterDate(periodStart, periodEnd).select('SI');
        var imageCount = periodImages.size();
        var composite = ee.Algorithms.If(
            imageCount.gt(0),
            periodImages.median().float(),
            ee.Image.constant(0).float().rename('SI').updateMask(ee.Image.constant(0))
        );
        return ee.Image(composite).float()
            .set('system:time_start', midDate.millis())
            .set('DOY', doy)
            .set('period_index', periodIndex)
            .set('image_count', imageCount);
    });
    var rawSIComposites = ee.ImageCollection.fromImages(siCompositesList);
    
    // S2 observation density 
    var s2ObsDensity = ee.ImageCollection.fromImages(
        periodSeq.map(function(periodIndex) {
            periodIndex = ee.Number(periodIndex);
            var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
            var periodEnd = periodStart.advance(compositePeriod, 'day');
            var periodImages = s2WithSI.filterDate(periodStart, periodEnd).select('SI');
            var hasData = periodImages.size().gt(0);
            var countImg = ee.Algorithms.If(hasData,
                periodImages.count().float().rename('obs_count'),
                ee.Image.constant(0).float().rename('obs_count'));
            return ee.Image(countImg);
        })
    ).sum().rename('total_obs_count').updateMask(extendedMask).clip(studyArea);

    progressCallback('Gap filling (linear interpolation)...');
    var overallSIStats = s2WithSI.select('SI').reduce(ee.Reducer.mean());
    var overallMean = overallSIStats;
    
    var compositeList = rawSIComposites.toList(rawSIComposites.size());
    var numComposites = rawSIComposites.size();
    
    var filledSIComposites = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numComposites.subtract(1)).map(function(idx) {
            idx = ee.Number(idx);
            var currentImg = ee.Image(compositeList.get(idx));
            var currentSI = currentImg.select('SI').float();
            var currentDoy = ee.Number(currentImg.get('DOY'));
            var hasCurrent = currentSI.mask().reduce(ee.Reducer.min());
            
            // 向前搜索最近有效影像
            var searchRange = 4;
            var beforeCandidates = ee.List.sequence(
                idx.subtract(searchRange).max(0), idx.subtract(1).max(0)
            ).map(function(bi) {
                var bImg = ee.Image(compositeList.get(bi));
                return bImg.select('SI').float()
                    .addBands(ee.Image.constant(ee.Number(bImg.get('DOY'))).float().rename('bDOY'))
                    .addBands(ee.Image.constant(ee.Number(bi)).float().rename('bIdx'));
            });
            // 取最近的（index最大的）有数据像元
            var beforeStack = ee.ImageCollection.fromImages(beforeCandidates);
            var beforeBest = beforeStack.map(function(img) {
                var quality = img.select('bIdx'); // 越大越近
                return img.addBands(quality.rename('quality'));
            }).qualityMosaic('quality');
            var beforeSI = beforeBest.select('SI');
            var beforeDOY = beforeBest.select('bDOY');
            
            // 向后搜索最近有效影像
            var afterCandidates = ee.List.sequence(
                idx.add(1).min(numComposites.subtract(1)),
                idx.add(searchRange).min(numComposites.subtract(1))
            ).map(function(ai) {
                var aImg = ee.Image(compositeList.get(ai));
                return aImg.select('SI').float()
                    .addBands(ee.Image.constant(ee.Number(aImg.get('DOY'))).float().rename('aDOY'))
                    .addBands(ee.Image.constant(ee.Number(ai)).float().rename('aIdx'));
            });
            var afterStack = ee.ImageCollection.fromImages(afterCandidates);
            var afterBest = afterStack.map(function(img) {
                var quality = img.select('aIdx').multiply(-1); // 越小越近
                return img.addBands(quality.rename('quality'));
            }).qualityMosaic('quality');
            var afterSI = afterBest.select('SI');
            var afterDOY = afterBest.select('aDOY');
            
            // 线性插值: SI = SI_before + (SI_after - SI_before) * (doy - doy_before) / (doy_after - doy_before)
            var doyDiff = afterDOY.subtract(beforeDOY).max(1);
            var weight = ee.Image.constant(currentDoy).subtract(beforeDOY).divide(doyDiff).clamp(0, 1);
            var interpolated = beforeSI.add(afterSI.subtract(beforeSI).multiply(weight)).float();
            
            // 只有一侧有数据时用该侧
            var hasBefore = beforeSI.mask().reduce(ee.Reducer.min());
            var hasAfter = afterSI.mask().reduce(ee.Reducer.min());
            var hasBoth = hasBefore.and(hasAfter);
            
            var filled = currentSI
                .unmask(interpolated.updateMask(hasBoth))
                .unmask(beforeSI.updateMask(hasBefore))
                .unmask(afterSI.updateMask(hasAfter))
                .unmask(overallMean)
                .float();
            
            return currentImg.addBands(filled.rename('SI_filled'), null, true);
        })
    );
    
    
    var rawSIPercentiles = rawSIComposites.select('SI').reduce(
        ee.Reducer.percentile([5, 95])
    );
    var siFloor = rawSIPercentiles.select('SI_p5');
    var siCeil  = rawSIPercentiles.select('SI_p95');
    
    filledSIComposites = filledSIComposites.map(function(img) {
        var original = img.select('SI_filled');
        var clamped = original.max(siFloor).min(siCeil).float().rename('SI_filled');
        return img.addBands(clamped, null, true)
            .copyProperties(img, ['system:time_start', 'DOY', 'period_index', 'image_count']);
    });
    
    var doyList = filledSIComposites.aggregate_array('DOY');
    progressCallback('Base data ready');
    
    
    // 记录每个周期每个像元是否有"真实S2观测"（非插值）
    var s2ValidObsMasks = ee.ImageCollection.fromImages(
        periodSeq.map(function(periodIndex) {
            periodIndex = ee.Number(periodIndex);
            var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
            var periodEnd = periodStart.advance(compositePeriod, 'day');
            var midDate = periodStart.advance(compositePeriod / 2, 'day');
            var periodImages = s2WithSI.filterDate(periodStart, periodEnd).select('SI');
            
            // 1 = 该周期有真实S2观测, 0 = 无观测（将被插值填充）
            var hasObs = ee.Algorithms.If(
                periodImages.size().gt(0),
                periodImages.count().gt(0).float().rename('has_real_obs'),
                ee.Image.constant(0).float().rename('has_real_obs')
            );
            
            return ee.Image(hasObs)
                .set('system:time_start', midDate.millis())
                .set('DOY', midDate.getRelative('day', 'year'))
                .set('period_index', periodIndex);
        })
    );
    
    
    return {
        filledSIComposites: filledSIComposites,
        rawSIComposites: rawSIComposites,
        s2WithAllIndices: s2WithAllIndices,
        s2ObsDensity: s2ObsDensity,
        s2ValidObsMasks: s2ValidObsMasks,
        doyList: doyList,
        startDateEE: startDateEE,
        periodSeq: periodSeq,
        modis: modis
    };
}

