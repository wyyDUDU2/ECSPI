// ─── R1: Load Period Rainfall ───────────────────────────────────────────────
rainStep1Btn.onClick(function() {
    if (!globalCache.filledSIComposites || !globalCache.periodSeq) {
        rainStatus.setValue('ERROR: Run M1 Step 1 first to load base data!');
        return;
    }
    
    if (globalCache.periodRainfall) {
        rainStatus.setValue('Period rainfall cached, verifying...');
        globalCache.periodRainfall.first().bandNames().evaluate(function(b, e) {
            if (e) { globalCache.periodRainfall = null; rainStatus.setValue('Cache invalid'); return; }
            rainStatus.setValue('Period rainfall loaded (cached)');
            globalStatusLabel.setValue('R1: Using cache');
        });
        return;
    }
    
    rainStatus.setValue('Loading CHIRPS daily precipitation...');
    globalStatusLabel.setValue('R1: Loading per-period rainfall...');
    
    var yr = globalCache.year;
    var startDateEE = globalCache.startDateEE;
    var periodSeq = globalCache.periodSeq;
    
    var chirps = ee.ImageCollection('UCSB-CHG/CHIRPS/DAILY')
        .filterBounds(studyArea).select('precipitation');
    
    var periodRainfall = ee.ImageCollection.fromImages(
        periodSeq.map(function(periodIndex) {
            periodIndex = ee.Number(periodIndex);
            var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
            var periodEnd = periodStart.advance(compositePeriod, 'day');
            var midDate = periodStart.advance(compositePeriod / 2, 'day');
            
            var periodRain = chirps.filterDate(periodStart, periodEnd).sum()
                .rename('period_rain').float().clip(studyArea);
            
            // 单日最大降雨（识别暴雨事件）
            var maxDaily = chirps.filterDate(periodStart, periodEnd)
                .max().rename('max_daily_rain').float().clip(studyArea);
            
            return periodRain.addBands(maxDaily)
                .set('system:time_start', midDate.millis())
                .set('DOY', midDate.getRelative('day', 'year'))
                .set('period_index', periodIndex);
        })
    );
    
    periodRainfall.first().bandNames().evaluate(function(bands, error) {
        if (error) {
            rainStatus.setValue('ERROR: CHIRPS load failed - ' + error);
            globalStatusLabel.setValue('R1: FAILED');
            return;
        }
        globalCache.periodRainfall = periodRainfall;
        
        var rainSummary = periodRainfall.select('period_rain').reduce(
            ee.Reducer.mean().combine(ee.Reducer.stdDev(), null, true)
                .combine(ee.Reducer.max(), null, true)
        );
        rainSummary.reduceRegion({
            reducer: ee.Reducer.mean(),
            geometry: studyArea,
            scale: 5000,
            bestEffort: true
        }).evaluate(function(stats) {
            var txt = 'Per-period rainfall stats:\n';
            if (stats) {
                txt += 'Mean: ' + safeToFixed(stats['period_rain_mean'], 1) + ' mm\n';
                txt += 'Std: ' + safeToFixed(stats['period_rain_stdDev'], 1) + ' mm\n';
                txt += 'Max: ' + safeToFixed(stats['period_rain_max'], 1) + ' mm';
            }
            rainStatus.setValue('R1 complete');
            rainResults.setValue(txt);
            globalStatusLabel.setValue('R1: Complete');
        });
    });
});

// ─── R2: Adaptive Quality Assessment ────────────────────────────────────────
// 
// 物理依据:
//   降雨通过三条路径影响光谱观测质量:
//   (a) 大气路径: 水汽增加→NIR/RE散射增强→SI偏高
//   (b) 地表效应: 土壤含水量升高→反射率改变→NDVI/SI对比度异常
//   (c) 冠层效应: 叶片含水量→RE/NIR吸收特征偏移
//
// 自适应阈值:
//   取 max(P75, 5mm)
// 暴雨检测:
//   单日 > 20mm → 不论累积是否超阈值，该周期均标记不可信
//   物理依据: 暴雨引发严重大气散射和地表径流

