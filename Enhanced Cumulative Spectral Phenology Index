m3Step2Btn.onClick(function() {
    if (!globalCache.s2WithAllIndices) {
        m3Status.setValue('ERROR: Run Step 3.1 first!');
        return;
    }
    
    m3Status.setValue('Generating features (stats + phenology)...');
    globalStatusLabel.setValue('M3: Temporal stats + shared-T1T2 phenology...');
    
    var startDateEE = globalCache.startDateEE;
    var periodSeq = globalCache.periodSeq;
    
    // ── 构建多指数复合影像 ──
    var allIndicesCompositesList = periodSeq.map(function(periodIndex) {
        periodIndex = ee.Number(periodIndex);
        var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
        var periodEnd = periodStart.advance(compositePeriod, 'day');
        var midDate = periodStart.advance(compositePeriod / 2, 'day');
        var doy = midDate.getRelative('day', 'year');
        
        var periodImages = globalCache.s2WithAllIndices
            .filterDate(periodStart, periodEnd)
            .select(['NDVI', 'EVI', 'LSWI', 'NDWI', 'BSI']);
        
        var composite = ee.Algorithms.If(
            periodImages.size().gt(0),
            periodImages.median().float(),
            ee.Image.constant([0,0,0,0,0]).float()
                .rename(['NDVI', 'EVI', 'LSWI', 'NDWI', 'BSI'])
                .updateMask(ee.Image.constant(0))
        );
        
        return ee.Image(composite).float()
            .set('system:time_start', midDate.millis())
            .set('DOY', doy)
            .set('period_index', periodIndex);
    });
    
    globalCache.rawAllIndicesComposites = ee.ImageCollection.fromImages(allIndicesCompositesList);
    
    // ── Part A: 时序统计特征 (20 bands) ── 不变
    var ndviStats = computeTemporalStats(globalCache.rawAllIndicesComposites, 'NDVI');
    var eviStats  = computeTemporalStats(globalCache.rawAllIndicesComposites, 'EVI');
    var lswiStats = computeTemporalStats(globalCache.rawAllIndicesComposites, 'LSWI');
    var ndwiStats = computeTemporalStats(globalCache.rawAllIndicesComposites, 'NDWI');
    var bsiStats  = computeTemporalStats(globalCache.rawAllIndicesComposites, 'BSI');
    
    // ── Part B: 物候特征 — NDVI 锚定 T1/T2，其余共享 ──
    // 只有 NDVI 做完整检测（SG + 二阶导 + T1/T2）—— 不变
    m3Status.setValue('Extracting NDVI phenology (full T1/T2 detection)...');
    var ndviPheno = extractIndexPhenology(
    globalCache.rawAllIndicesComposites, 'NDVI', globalCache.doyList, 
    extendedMask, 'NDVI', false);
    
    // 提取共享 T1/T2 —— 不变
    var sharedT1 = ndviPheno.select('NDVI_T1');
    var sharedT2 = ndviPheno.select('NDVI_T2');
    
    // ★ 改动：4个指数合并为一次批量提取（替换原来的4次独立调用）
    m3Status.setValue('Extracting EVI/LSWI/NDWI/BSI with shared T1/T2 (batched)...');
    var otherPheno = extractBatchPhenologyWithSharedT1T2(
    globalCache.rawAllIndicesComposites,
    ['EVI', 'LSWI', 'NDWI', 'BSI'],
    globalCache.doyList,
    extendedMask,              // ← extendedMask
    sharedT1, sharedT2
);
    
    // ★ 合并：ndviPheno(7) + otherPheno(28) = 35 物候波段，波段名完全一致
    var featuresTemp = ee.Image.cat([
        ndviStats, eviStats, lswiStats, ndwiStats, bsiStats,
        ndviPheno, otherPheno
    ]).clip(studyArea);
    
    m3Status.setValue('Verifying features on server...');
    featuresTemp.bandNames().evaluate(function(bands, error) {
        if (error) {
            m3Status.setValue('ERROR: Features failed - ' + error);
            globalStatusLabel.setValue('M3 Step 2: FAILED');
            m3_features = null;
            return;
        }
        m3_features = featuresTemp;
