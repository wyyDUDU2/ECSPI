// 12.5b: Fig.7 — CSP 分布叠加直方图
// ──────────────────────────────────────────────────────────────────────────
function plotCSPDistribution(cspImage, bandName, cottonSamplesFC, otherSamplesFC, title) {
    var cottonCSP = cspImage.sampleRegions({
        collection: cottonSamplesFC, properties: ['class'],
        scale: outputScale, tileScale: tileScale
    });
    var otherCSP = cspImage.sampleRegions({
        collection: otherSamplesFC, properties: ['class'],
        scale: outputScale, tileScale: tileScale
    });

    cottonCSP.aggregate_array(bandName).evaluate(function(cottonVals, err1) {
        if (err1) { print('ERROR (cotton): ' + err1); return; }
        otherCSP.aggregate_array(bandName).evaluate(function(otherVals, err2) {
            if (err2) { print('ERROR (noncotton): ' + err2); return; }

            var allVals = cottonVals.concat(otherVals);
            var globalMin = Math.min.apply(null, allVals);
            var globalMax = Math.max.apply(null, allVals);
            var nBins = 50;
            var binWidth = (globalMax - globalMin) / nBins;
            if (binWidth <= 0) { print('Warning: zero range'); return; }

            var cottonHist = zeroArray(nBins);
            var otherHist = zeroArray(nBins);

            for (var i = 0; i < cottonVals.length; i++) {
                var idx = Math.min(Math.floor((cottonVals[i] - globalMin) / binWidth), nBins - 1);
                if (idx >= 0) cottonHist[idx]++;
            }
            for (var j = 0; j < otherVals.length; j++) {
                var idx2 = Math.min(Math.floor((otherVals[j] - globalMin) / binWidth), nBins - 1);
                if (idx2 >= 0) otherHist[idx2]++;
            }

            var rows = [['CSP', 'Cotton', 'Noncotton']];
            for (var k = 0; k < nBins; k++) {
                var binCenter = globalMin + (k + 0.5) * binWidth;
                rows.push([binCenter, cottonHist[k], otherHist[k]]);
            }

            var chart = ui.Chart(rows, 'ColumnChart', {
                title: title,
                hAxis: {title: 'CSP'},
                vAxis: {title: 'Count'},
                colors: ['#E53935', '#42A5F5'],
                legend: {position: 'top'},
                bar: {groupWidth: '100%'},
                isStacked: false
            });
            print(chart);
        });
    });
}


