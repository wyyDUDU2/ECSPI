//2.5 Fusion Weights
m2Step5Btn.onClick(function() {
    if (!globalCache.CSP_s2only || !globalCache.CSP_modis) {
        m2Status.setValue('ERROR: Run Step 2.4 first!');
        return;
    }
    
    if (globalCache.fusionWeights) {
        m2Status.setValue('Weights cached, verifying...');
        globalCache.fusionWeights.bandNames().evaluate(function(bands, error) {
            if (error) {
                m2Status.setValue('Cache invalid, recomputing...');
                globalCache.fusionWeights = null;
                globalCache._obsPercentiles = null;
                return;
            }
            m2Status.setValue('Weights cached (verified)');
            globalStatusLabel.setValue('M2 Step 5: Using cache');
        });
        return;
    }
    
    m2Status.setValue('Pre-computing obs percentiles...');
    globalStatusLabel.setValue('M2: Obs density percentiles...');
    
    // ====== 第1步: 预计算百分位数（evaluate到客户端，打断计算图） ======
    var obsSource = globalCache.effectiveObsDensity 
        ? globalCache.effectiveObsDensity 
        : globalCache.s2ObsDensity;
    
    var obsStats = obsSource.updateMask(extendedMask).reduceRegion({
        reducer: ee.Reducer.percentile([10, 90]),
        geometry: studyArea,
        scale: analysisScale,
        maxPixels: 1e13,
        bestEffort: true,
        tileScale: tileScale
    });
    
    obsStats.evaluate(function(statsDict, error) {
        if (error) {
            m2Status.setValue('ERROR: Obs stats failed - ' + error);
            globalStatusLabel.setValue('M2 Step 5: FAILED');
            return;
        }
        
        // 获取实际的 band name（可能是 total_obs_count_p10 或 effective_obs_density_p10）
        var keys = Object.keys(statsDict);
        var p10Val = null, p90Val = null;
        for (var k = 0; k < keys.length; k++) {
            if (keys[k].indexOf('p10') !== -1) p10Val = statsDict[keys[k]];
            if (keys[k].indexOf('p90') !== -1) p90Val = statsDict[keys[k]];
        }
        
        p10Val = (p10Val !== null && p10Val !== undefined) ? Math.max(p10Val, 1) : 1;
        p90Val = (p90Val !== null && p90Val !== undefined) ? Math.max(p90Val, 3) : 3;
        
        // 缓存为客户端数值
        globalCache._obsPercentiles = { p10: p10Val, p90: p90Val };
        
        m2Status.setValue('Obs P10=' + safeToFixed(p10Val, 1) + 
                         ' P90=' + safeToFixed(p90Val, 1) + '. Computing weights...');
        
        // ====== 第2步: 构建权重影像（此时百分位数已经是常量，不引用reduceRegion） ======
        var weights = computeAdaptiveFusionWeightsPixelWise(
            globalCache.CSP_s2only,
            globalCache.CSP_modis,
            globalCache.s2ObsDensity,
            extendedMask
        );
        
        weights.bandNames().evaluate(function(bands, error2) {
            if (error2) {
                m2Status.setValue('ERROR: Weights failed - ' + error2);
                globalStatusLabel.setValue('M2 Step 5: FAILED');
                return;
            }
            globalCache.fusionWeights = weights;
            m2Status.setValue('Weights complete (verified)');
            globalStatusLabel.setValue('M2 Step 5: Complete');
            Map.addLayer(globalCache.fusionWeights, {
                min: 0.2, max: 0.9, 
                palette: ['red', 'yellow', 'green']
            }, 'S2 Weight', false);
            print('Fusion weights: P10=' + p10Val + ' P90=' + p90Val);
        });
    });
});


//2.6 Normalize & Fuse CSP
m2Step6Btn.onClick(function() {
    if (!globalCache.fusionWeights) {
        m2Status.setValue('ERROR: Run Step 2.5 first!');
        return;
    }
    
    if (globalCache.CSP_fused) {
        m2Status.setValue('CSP fused cached, verifying...');
        globalCache.CSP_fused.bandNames().evaluate(function(bands, error) {
            if (error) {
                m2Status.setValue('Cache invalid, recomputing...');
                globalCache.CSP_fused = null;
                return;
            }
            m2Status.setValue('CSP fused cached (verified)');
            globalStatusLabel.setValue('M2 Step 6: Using cache');
        });
        return;
    }
    
    m2Status.setValue('Computing S2 stats...');
    globalStatusLabel.setValue('M2: Normalizing CSP...');
    
    var cspS2Stats = globalCache.CSP_s2only.reduceRegion({
        reducer: ee.Reducer.mean().combine(ee.Reducer.stdDev(), null, true),
        geometry: studyArea,
        scale: analysisScale,
        maxPixels: 1e13,
        bestEffort: true,
        tileScale: 8
    });
    
    cspS2Stats.evaluate(function(s2Stats, error1) {
        if (error1) {
            m2Status.setValue('ERROR: S2 stats failed - ' + error1);
            globalStatusLabel.setValue('M2 Step 6: S2 FAILED');
            return;
        }
        
        m2Status.setValue('S2 stats done. Computing MODIS stats...');
        
        var cspModisStats = globalCache.CSP_modis.updateMask(extendedMask).reduceRegion({
            reducer: ee.Reducer.mean().combine(ee.Reducer.stdDev(), null, true),
            geometry: studyArea,
            scale: analysisScale,
            maxPixels: 1e13,
            bestEffort: true,
            tileScale: 8
        });
        
        cspModisStats.evaluate(function(modisStats, error2) {
            if (error2) {
                m2Status.setValue('ERROR: MODIS stats failed - ' + error2);
                globalStatusLabel.setValue('M2 Step 6: MODIS FAILED');
                return;
            }
            
            m2Status.setValue('Fusing CSP (improved strategy)...');
            
            var cspS2Mean = ee.Number(s2Stats['CSP_s2only_mean']);
            var cspS2Std = ee.Number(s2Stats['CSP_s2only_stdDev']).max(0.0001);
            var cspModisMean = ee.Number(modisStats['CSP_MODIS_mean']);
var cspModisStd = ee.Number(modisStats['CSP_MODIS_stdDev']).max(0.0001);

var CSP_modis_aligned = globalCache.CSP_modis
    .subtract(cspModisMean)
    .divide(cspModisStd)
    .multiply(cspS2Std)
    .add(cspS2Mean);

// Step B: 修改权重策略 —— 大幅提高S2权重下限，限制MODIS影响
var w_modis = ee.Image.constant(1).subtract(globalCache.fusionWeights);

// 关键改动：对w_modis做平方，让MODIS权重大幅缩小
// 原来w_s2范围[0.3, 0.95]，w_modis=[0.05, 0.7]
// 平方后w_modis=[0.0025, 0.49]，S2主导性大幅增强
var w_modis_dampened = w_modis.pow(2);
var w_s2_dampened = ee.Image.constant(1).subtract(w_modis_dampened);

var fused = globalCache.CSP_s2only.multiply(w_s2_dampened)
    .add(CSP_modis_aligned.multiply(w_modis_dampened))
    .rename('CSP_fused')
    .updateMask(extendedMask)
    .clip(studyArea);
            
            // Step C: 残差校正
            var residual = fused.subtract(globalCache.CSP_s2only);
            var residualMean = residual.reduceRegion({
                reducer: ee.Reducer.mean(),
                geometry: studyArea,
                scale: analysisScale,
                maxPixels: 1e13,
                bestEffort: true,
                tileScale: 8
            });
            
            residualMean.evaluate(function(resMeanDict, resError) {
                var resBias = 0;
                if (!resError && resMeanDict && resMeanDict['CSP_fused'] !== null) {
                    resBias = resMeanDict['CSP_fused'];
                }
                
                var fusedCorrected = fused.subtract(ee.Number(resBias * 0.5))
                    .rename('CSP_fused')
                    .updateMask(extendedMask)
                    .clip(studyArea);
                
                // ====== 验证 & 赋值缓存 ======
                fusedCorrected.bandNames().evaluate(function(bands, error3) {
                    if (error3) {
                        m2Status.setValue('ERROR: Fusion failed - ' + error3);
                        globalStatusLabel.setValue('M2 Step 6: FAILED');
                        return;
                    }
                  globalCache.CSP_fused = fusedCorrected;
                    globalCache.CSP_fused_m2 = fusedCorrected;   // 保存M2独立副本
                    
                    m2Status.setValue('CSP fused (bias correction=' + safeToFixed(resBias * 0.5, 4) + ')');
                    m2Results.setValue(
                        'S2 mean: ' + safeToFixed(s2Stats['CSP_s2only_mean'], 4) +
                        ' std: ' + safeToFixed(s2Stats['CSP_s2only_stdDev'], 4) +
                        '\nMODIS mean: ' + safeToFixed(modisStats['CSP_MODIS_mean'], 4) +
                        ' std: ' + safeToFixed(modisStats['CSP_MODIS_stdDev'], 4) +
                        '\nResidual bias: ' + safeToFixed(resBias, 4) +
                        '\nCorrection applied: ' + safeToFixed(resBias * 0.5, 4)
                    );
                    globalStatusLabel.setValue('M2 Step 6: Complete');
                    Map.addLayer(fusedCorrected, {min: -0.5, max: 1.5, 
                        palette: ['0000FF', 'FFFFFF', 'FF0000']}, 'CSP Fused', false);
                    print('M2 Step 6: CSP fused verified, bias correction=' + safeToFixed(resBias * 0.5, 4));
                });
            }); // end residualMean.evaluate
        }); // end cspModisStats.evaluate
    }); // end cspS2Stats.evaluate
});
 



