            rainStatus.setValue('Quality mask cached (verified)');
            globalStatusLabel.setValue('R2: Using cache');
        });
        return;
    }
    
    rainStatus.setValue('Computing adaptive rainfall threshold...');
    globalStatusLabel.setValue('R2: Quality assessment...');
    
