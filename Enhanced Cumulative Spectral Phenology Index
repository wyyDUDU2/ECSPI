                txt += 'Threshold: max(P75, 5mm) = ' + safeToFixed(adaptiveThreshold, 1) + ' mm\n';
                txt += 'Heavy rain: >' + heavyRainDaily + ' mm/day\n';
                txt += 'Periods: ' + nPeriods + ' total\n';
