// ─── R3: Mask Unreliable Observations (NO re-interpolation) ────────────────
//
// 核心逻辑:
//   将被R2标记为不可信的周期SI值设为masked
//   只对降雨去噪过滤数据做线性插值——保留缺口，让M2融合用MODIS填补
rainStep3Btn.onClick(function() {
    if (!globalCache.rainQualityMask || !globalCache.rawSIComposites || !globalCache.filledSIComposites) {
        rainStatus.setValue('ERROR: Run R2 first & ensure base data loaded!');
        return;
    }
    if (!globalCache.modis) {
        rainStatus.setValue('ERROR: MODIS data missing! Run M1/M2 Step 1 first.');
        return;
    }
    
    rainStatus.setValue('Building period-aligned MODIS NDVI...');
    globalStatusLabel.setValue('R3: MODIS-guided rain correction...');
    
    var rawComposites = globalCache.rawSIComposites;
    var filledComposites = globalCache.filledSIComposites;
    var qualityMask = globalCache.rainQualityMask;
    var periodSeq = globalCache.periodSeq;
    var startDateEE = globalCache.startDateEE;
    
    // ── 阈值常量（从R2缓存读取，保持一致） ──
    var adaptiveThreshold = globalCache.rainThreshold || 10.0;
    var heavyRainDaily = 20.0;
    var threshImage = ee.Image.constant(adaptiveThreshold).float();
    var heavyRainImage = ee.Image.constant(heavyRainDaily).float();
    
    // ======================================================================
    // Step 0: 构建与S2同周期对齐的MODIS NDVI复合影像
    // ======================================================================
    var modisNDVIRaw = globalCache.modis.map(function(image) {
        return image.select('NDVI').multiply(0.0001).float().rename('MODIS_NDVI')
            .copyProperties(image, ['system:time_start']);
    });
    var modisGlobalMedian = modisNDVIRaw.median();
    
    var modisComposites = ee.ImageCollection.fromImages(
        periodSeq.map(function(periodIndex) {
            periodIndex = ee.Number(periodIndex);
            var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
            var periodEnd = periodStart.advance(compositePeriod, 'day');
            var midDate = periodStart.advance(compositePeriod / 2, 'day');
            var mFiltered = modisNDVIRaw.filterDate(
                periodStart.advance(-8, 'day'),
                periodEnd.advance(8, 'day')
            );
            var composite = ee.Algorithms.If(
                mFiltered.size().gt(0),
                mFiltered.median().float(),
                modisGlobalMedian.float()
            );
            return ee.Image(composite).float()
                .set('system:time_start', midDate.millis())
                .set('DOY', midDate.getRelative('day', 'year'))
                .set('period_index', periodIndex);
        })
    );
    
    var rawList    = rawComposites.toList(rawComposites.size());
    var filledList = filledComposites.toList(filledComposites.size());
    var maskList   = qualityMask.toList(qualityMask.size());
    var modisList  = modisComposites.toList(modisComposites.size());
    var numPeriods = rawComposites.size();
    
    // ======================================================================
    // ── 通用：计算混合权重 alpha ──
    //
    // alpha = 对当前周期S2观测的不信任程度（0=完全信任S2，1=完全用MODIS引导值）
    //
    // 计算逻辑（逐像元）:
    //   excessRatio = cumRain / threshold，clamp到[1,5]
    //   alpha_raw   = (excessRatio-1)/4，clamp到[0.1,0.9]
    //     → 刚超阈值(ratio=1) → alpha=0.1  → 保留90%S2
    //     → 2×阈值(ratio=2)   → alpha=0.35
    //     → ≥5×阈值(ratio≥5)  → alpha=0.9
    //   暴雨覆盖: max_daily≥20mm → alpha=0.95
    //   一致性保护: |MODIS引导值 - S2原值| < 0.15 → alpha=0（不修正）
    // ======================================================================
    function computeAlpha(cumRain, maxDaily, rawSIVal, rainFillVal) {
        var excessRatio = cumRain.divide(threshImage.max(1)).clamp(1, 5);
        var alpha = excessRatio.subtract(1).divide(4).clamp(0.1, 0.9).float();
        
        // 暴雨：强制接近全替换
        alpha = alpha.where(maxDaily.gte(heavyRainImage), 0.95);
        
        // 一致性保护：MODIS与S2差异小 → 原始观测本身可靠 → 不做修正
        var absDiff = rainFillVal.subtract(rawSIVal).abs();
        var modisConsistent = absDiff.lt(0.15);
        alpha = alpha.where(modisConsistent, 0);
        
        return alpha.float();
    }
    
    // ======================================================================
    // Part A: 修复 rawSIComposites（用于CSP计算）
    // ======================================================================
    
    rainStatus.setValue('Part A: MODIS-guided raw SI correction (proportional blend)...');
    
    // A1: 可信S2观测集合（仅用于搜索锚点）
    var reliableRawObs = ee.ImageCollection.fromImages(
        periodSeq.map(function(i) {
            i = ee.Number(i);
            var rawImg = ee.Image(rawList.get(i));
            var qMask  = ee.Image(maskList.get(i)).select('reliable');
            return rawImg.select('SI').updateMask(qMask).float().rename('SI')
                .copyProperties(rawImg, ['system:time_start', 'DOY', 'period_index', 'image_count']);
        })
    );
    var reliableRawList = reliableRawObs.toList(reliableRawObs.size());
    
    // A2: 逐周期MODIS引导插值 + 比例混合
    var correctedRaw = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(idx) {
            idx = ee.Number(idx);
            var rawImg       = ee.Image(rawList.get(idx));
            var rawSI        = rawImg.select('SI').float();
            var currentDoy   = ee.Number(rawImg.get('DOY'));
            var qMask        = ee.Image(maskList.get(idx)).select('reliable');
            var currentModis = ee.Image(modisList.get(idx)).select('MODIS_NDVI').float();
            
            // 降雨周期数据：用于计算alpha
            var periodRainImg = globalCache.periodRainfall
                ? ee.Image(globalCache.periodRainfall.toList(
                    globalCache.periodRainfall.size()).get(idx))
                : null;
            var cumRain  = periodRainImg 
                ? periodRainImg.select('period_rain').float()
                : threshImage;   // 无降雨数据时退化为阈值（alpha最小值0.1）
            var maxDaily = periodRainImg
                ? periodRainImg.select('max_daily_rain').float()
                : ee.Image.constant(0).float();
            
            // 判断：有真实S2观测但降雨不可信
            var hasRealObs   = rawSI.mask().reduce(ee.Reducer.min());
            var rainUnreliable = hasRealObs.and(qMask.not());
            
            var searchRange = 6;
            
            // ── 向前搜索：最近可信S2 + 对应MODIS NDVI ──
            var beforeCandidates = ee.List.sequence(
                idx.subtract(searchRange).max(0), idx.subtract(1).max(0)
            ).map(function(bi) {
                var bImg   = ee.Image(reliableRawList.get(bi));
                var bModis = ee.Image(modisList.get(bi)).select('MODIS_NDVI').float();
                return bImg.select('SI').float()
                    .addBands(bModis.rename('bModis'))
                    .addBands(ee.Image.constant(ee.Number(bImg.get('DOY'))).float().rename('bDOY'))
                    .addBands(ee.Image.constant(ee.Number(bi)).float().rename('bIdx'));
            });
            var beforeBest = ee.ImageCollection.fromImages(beforeCandidates)
                .map(function(img) { return img.addBands(img.select('bIdx').rename('quality')); })
                .qualityMosaic('quality');
            var beforeSI    = beforeBest.select('SI');
            var beforeModis = beforeBest.select('bModis');
            var beforeDOY   = beforeBest.select('bDOY');
            
            // ── 向后搜索：最近可信S2 + 对应MODIS NDVI ──
            var afterCandidates = ee.List.sequence(
                idx.add(1).min(numPeriods.subtract(1)),
                idx.add(searchRange).min(numPeriods.subtract(1))
            ).map(function(ai) {
                var aImg   = ee.Image(reliableRawList.get(ai));
                var aModis = ee.Image(modisList.get(ai)).select('MODIS_NDVI').float();
                return aImg.select('SI').float()
                    .addBands(aModis.rename('aModis'))
                    .addBands(ee.Image.constant(ee.Number(aImg.get('DOY'))).float().rename('aDOY'))
                    .addBands(ee.Image.constant(ee.Number(ai)).float().rename('aIdx'));
            });
            var afterBest = ee.ImageCollection.fromImages(afterCandidates)
                .map(function(img) { return img.addBands(img.select('aIdx').multiply(-1).rename('quality')); })
                .qualityMosaic('quality');
            var afterSI    = afterBest.select('SI');
            var afterModis = afterBest.select('aModis');
            var afterDOY   = afterBest.select('aDOY');
            
            var hasBefore = beforeSI.mask().reduce(ee.Reducer.min());
            var hasAfter  = afterSI.mask().reduce(ee.Reducer.min());
            var hasBoth   = hasBefore.and(hasAfter);
            
            // ── 双侧锚点：MODIS引导加权插值 ──
            var doyDiff    = afterDOY.subtract(beforeDOY).max(1);
            var timeWeight = ee.Image.constant(currentDoy).subtract(beforeDOY)
                .divide(doyDiff).clamp(0, 1);
            var modisRange    = afterModis.subtract(beforeModis).float();
            var modisRangeAbs = modisRange.abs();
            var modisWeightRaw = currentModis.subtract(beforeModis)
                .divide(modisRange.where(modisRangeAbs.lt(0.01), 0.01))
                .clamp(0, 1);
            var modisWeight    = modisWeightRaw.where(modisRangeAbs.lt(0.01), timeWeight);
            var blendedWeight  = modisWeight.multiply(0.6).add(timeWeight.multiply(0.4));
            var bothInterp     = beforeSI.add(afterSI.subtract(beforeSI).multiply(blendedWeight)).float();
            
            // ── 单侧锚点：MODIS比值缩放 ──
            var ratioB       = currentModis.divide(beforeModis.max(0.01)).clamp(0.5, 2.0);
            var fillFromBefore = beforeSI.multiply(ratioB).float();
            var ratioA       = currentModis.divide(afterModis.max(0.01)).clamp(0.5, 2.0);
            var fillFromAfter  = afterSI.multiply(ratioA).float();
            
            // ── 组合MODIS引导值：双侧优先 > 前侧 > 后侧 ──
            var rainFill = fillFromBefore.updateMask(hasBefore)
                .unmask(fillFromAfter.updateMask(hasAfter));
            rainFill = rainFill.where(hasBoth, bothInterp);
            
            // ── 计算alpha（连续置信度） ──
            var alpha = computeAlpha(cumRain, maxDaily, rawSI, rainFill);
            
            // ── 比例混合：alpha=0时完全保留S2，alpha=1时完全用MODIS引导值 ──
            var blendedResult = rawSI
                .multiply(ee.Image.constant(1).subtract(alpha))
                .add(rainFill.multiply(alpha))
                .float();
            
            // 只替换降雨不可信像元；云缺失保持masked
            var result = rawSI.where(rainUnreliable, blendedResult).rename('SI');
            
            return result.copyProperties(rawImg,
                ['system:time_start', 'DOY', 'period_index', 'image_count']);
        })
    );
    
    // A3: P5-P95裁剪
    var rawPercentiles    = rawComposites.select('SI').reduce(ee.Reducer.percentile([5, 95]));
    var siFloor = rawPercentiles.select('SI_p5');
    var siCeil  = rawPercentiles.select('SI_p95');
    
    var correctedRawClamped = correctedRaw.map(function(img) {
        var si      = img.select('SI');
        var clamped = si.max(siFloor).min(siCeil).float().rename('SI');
        return clamped.copyProperties(img, ['system:time_start', 'DOY', 'period_index', 'image_count']);
    });
    
    // ======================================================================
    // Part B: 修复 filledSIComposites（用于T1/T2检测）
    // ======================================================================
    
    rainStatus.setValue('Part B: MODIS-guided filled SI correction (proportional blend)...');
    
    var reliableFilledObs = ee.ImageCollection.fromImages(
        periodSeq.map(function(i) {
            i = ee.Number(i);
            var fImg  = ee.Image(filledList.get(i));
            var qMask = ee.Image(maskList.get(i)).select('reliable');
            return fImg.select('SI_filled').updateMask(qMask).float().rename('SI_filled')
                .copyProperties(fImg, ['system:time_start', 'DOY', 'period_index', 'image_count']);
        })
    );
    var reliableFilledList = reliableFilledObs.toList(reliableFilledObs.size());
    
    var correctedFilled = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(idx) {
            idx = ee.Number(idx);
            var fImg        = ee.Image(filledList.get(idx));
            var originalSI  = fImg.select('SI_filled').float();
            var currentDoy  = ee.Number(fImg.get('DOY'));
            var qMask       = ee.Image(maskList.get(idx)).select('reliable');
            var isRainBad   = qMask.not();
            var currentModis = ee.Image(modisList.get(idx)).select('MODIS_NDVI').float();
            
            // 降雨周期数据
            var periodRainImg = globalCache.periodRainfall
                ? ee.Image(globalCache.periodRainfall.toList(
                    globalCache.periodRainfall.size()).get(idx))
                : null;
            var cumRain  = periodRainImg
                ? periodRainImg.select('period_rain').float()
                : threshImage;
            var maxDaily = periodRainImg
                ? periodRainImg.select('max_daily_rain').float()
                : ee.Image.constant(0).float();
            
            var searchRange = 6;
            
            // ── 向前搜索 ──
            var beforeCandidates = ee.List.sequence(
                idx.subtract(searchRange).max(0), idx.subtract(1).max(0)
            ).map(function(bi) {
                var bImg   = ee.Image(reliableFilledList.get(bi));
                var bModis = ee.Image(modisList.get(bi)).select('MODIS_NDVI').float();
                return bImg.select('SI_filled').float()
                    .addBands(bModis.rename('bModis'))
                    .addBands(ee.Image.constant(ee.Number(bImg.get('DOY'))).float().rename('bDOY'))
                    .addBands(ee.Image.constant(ee.Number(bi)).float().rename('bIdx'));
            });
            var beforeBest = ee.ImageCollection.fromImages(beforeCandidates)
                .map(function(img) { return img.addBands(img.select('bIdx').rename('quality')); })
                .qualityMosaic('quality');
            
            // ── 向后搜索 ──
            var afterCandidates = ee.List.sequence(
                idx.add(1).min(numPeriods.subtract(1)),
                idx.add(searchRange).min(numPeriods.subtract(1))
            ).map(function(ai) {
                var aImg   = ee.Image(reliableFilledList.get(ai));
                var aModis = ee.Image(modisList.get(ai)).select('MODIS_NDVI').float();
                return aImg.select('SI_filled').float()
                    .addBands(aModis.rename('aModis'))
                    .addBands(ee.Image.constant(ee.Number(aImg.get('DOY'))).float().rename('aDOY'))
                    .addBands(ee.Image.constant(ee.Number(ai)).float().rename('aIdx'));
            });
            var afterBest = ee.ImageCollection.fromImages(afterCandidates)
                .map(function(img) { return img.addBands(img.select('aIdx').multiply(-1).rename('quality')); })
                .qualityMosaic('quality');
            
            var beforeSI    = beforeBest.select('SI_filled');
            var beforeModis = beforeBest.select('bModis');
            var beforeDOY   = beforeBest.select('bDOY');
            var afterSI     = afterBest.select('SI_filled');
            var afterModis  = afterBest.select('aModis');
            var afterDOY    = afterBest.select('aDOY');
            
            var hasBefore = beforeSI.mask().reduce(ee.Reducer.min());
            var hasAfter  = afterSI.mask().reduce(ee.Reducer.min());
            var hasBoth   = hasBefore.and(hasAfter);
            
            // ── MODIS引导插值（与Part A完全一致） ──
            var doyDiff    = afterDOY.subtract(beforeDOY).max(1);
            var timeWeight = ee.Image.constant(currentDoy).subtract(beforeDOY)
                .divide(doyDiff).clamp(0, 1);
            var modisRange    = afterModis.subtract(beforeModis).float();
            var modisRangeAbs = modisRange.abs();
            var modisWeightRaw = currentModis.subtract(beforeModis)
                .divide(modisRange.where(modisRangeAbs.lt(0.01), 0.01))
                .clamp(0, 1);
            var modisWeight    = modisWeightRaw.where(modisRangeAbs.lt(0.01), timeWeight);
            var blendedWeight  = modisWeight.multiply(0.6).add(timeWeight.multiply(0.4));
            var bothInterp     = beforeSI.add(afterSI.subtract(beforeSI).multiply(blendedWeight)).float();
            
            var ratioB         = currentModis.divide(beforeModis.max(0.01)).clamp(0.5, 2.0);
            var fillFromBefore = beforeSI.multiply(ratioB).float();
            var ratioA         = currentModis.divide(afterModis.max(0.01)).clamp(0.5, 2.0);
            var fillFromAfter  = afterSI.multiply(ratioA).float();
            
            var rainFill = fillFromBefore.updateMask(hasBefore)
                .unmask(fillFromAfter.updateMask(hasAfter));
            rainFill = rainFill.where(hasBoth, bothInterp);
            
            // ── 计算alpha并比例混合 ──
            var alphaF = computeAlpha(cumRain, maxDaily, originalSI, rainFill);
            
            var blendedResultF = originalSI
                .multiply(ee.Image.constant(1).subtract(alphaF))
                .add(rainFill.multiply(alphaF))
                .float();
            
            // 降雨不可信 → 比例混合；云缺失 → 保持原有插值
            var result = originalSI.where(isRainBad, blendedResultF).rename('SI_filled');
            
            return fImg.addBands(result, null, true);
        })
    );
    
    // ======================================================================
    // Part C: 验证 & 更新缓存
    // ======================================================================
    
    correctedRawClamped.first().bandNames().evaluate(function(bands, error) {
        if (error) {
            rainStatus.setValue('ERROR: Rain correction failed - ' + error);
            globalStatusLabel.setValue('R3: FAILED');
            return;
        }
        
        globalCache.rawSIComposites     = correctedRawClamped;
        globalCache.filledSIComposites  = correctedFilled;
        rainCorrectionApplied = true;
        
        // 更新有效观测密度
        if (globalCache.s2ValidObsMasks && globalCache.rainQualityMask) {
            var validAfterRain = globalCache.s2ValidObsMasks.map(function(obsImg) {
                var periodIdx = obsImg.get('period_index');
                var rainMask  = globalCache.rainQualityMask
                    .filter(ee.Filter.eq('period_index', periodIdx))
                    .first()
                    .select('reliable');
                return obsImg.select('has_real_obs')
                    .multiply(rainMask)
                    .rename('effective_obs')
                    .copyProperties(obsImg, ['system:time_start', 'DOY', 'period_index']);
            });
            
            var effectiveObsDensity = validAfterRain.map(function(img) {
                var doy = ee.Number(img.get('DOY'));
                var inGrowingSeason = doy.gte(120).and(doy.lte(270));
                return ee.Image(ee.Algorithms.If(
                    inGrowingSeason,
                    img.select('effective_obs'),
                    ee.Image.constant(0).float().rename('effective_obs')
                ));
            }).sum().rename('effective_obs_density')
              .updateMask(extendedMask).clip(studyArea);
            
            //globalCache.effectiveObsDensity = effectiveObsDensity;
        }
        
        // 清除下游缓存
        globalCache.T1_image    = null;
        globalCache.T2_image    = null;
        globalCache.CSP_s2only  = null;
        
        globalCache.CSP_fused_m2  = null; 
        globalCache.CSP_modis   = null;
        globalCache.T1_modis    = null;
        globalCache.T2_modis    = null;
        globalCache.CSP_fused   = null;
        globalCache.fusionWeights        = null;
        globalCache._obsPercentiles      = null;
      
        globalCache.result_m2   = null;
        globalCache.result_m3   = null;
        globalCache.result_m4   = null;
        m1_otsuThreshold        = null;
        m1_sauvolaThreshold     = null;
        m2_otsuThreshold        = null;
        m2_finalThreshold       = null;
        m3_features             = null;
        m3_trainData            = null;
        m3_rfModel              = null;
        m4_ndviStats            = null;
        m4_features             = null;
        m4_trainData            = null;
        m4_rfModel              = null;
        
        // 统计（改用alpha均值替代原来的removed count，更能反映实际修正程度）
        var rainRemovedCount = globalCache.rainQualityMask.map(function(img) {
            return ee.Image.constant(1).subtract(img.select('reliable')).rename('removed');
        }).sum();
        
        rainRemovedCount.reduceRegion({
            reducer: ee.Reducer.mean(),
            geometry: studyArea,
            scale: analysisScale,
            maxPixels: 1e13,
            bestEffort: true,
            tileScale: tileScale
        }).evaluate(function(countStats) {
            var avgRemoved = countStats ? safeToFixed(countStats['removed'], 1) : 'N/A';
            
            var currentTxt = rainResults.getValue();
            rainResults.setValue(currentTxt +
                '\n--- R3 APPLIED (proportional blend) ---\n' +
                'Correction mode: alpha-weighted blend\n' +
                '  alpha=0.1: cumRain just above threshold\n' +
                '  alpha=0.5: cumRain=2×threshold\n' +
                '  alpha=0.95: heavy rain (max_daily≥20mm)\n' +
                '  alpha=0: MODIS consistent with S2 (<0.15 diff)\n' +
                'Avg rain periods flagged/pixel: ' + avgRemoved + '\n' +
                'Proceed to M1 Step 2.');
            rainStatus.setValue('R3 complete (proportional blend)');
            globalStatusLabel.setValue('R3: Complete. Re-run from M1 Step 2.');
        });
    });
});




// ─── R4: Diagnostic Visualization (optional) ────────────────────────────────
rainStep4Btn.onClick(function() {
    if (!globalCache.rainQualityMask) {
        rainStatus.setValue('Run R2 first');
        return;
    }
    
    rainStatus.setValue('Generating diagnostic...');
    
    var removedCount = globalCache.rainQualityMask.map(function(img) {
        return ee.Image.constant(1).subtract(img.select('reliable')).rename('removed');
    }).sum().rename('periods_removed');
    
    var totalPeriods = globalCache.rainQualityMask.size();
    
    removedCount.reduceRegion({
        reducer: ee.Reducer.mean().combine(ee.Reducer.max(), null, true),
        geometry: studyArea,
        scale: 5000,
        bestEffort: true
    }).evaluate(function(stats, error) {
        if (error) { rainStatus.setValue('Diagnostic error'); return; }
        
        totalPeriods.evaluate(function(nPeriods) {
            var txt = '=== Diagnostic ===\n';
            txt += 'Total periods: ' + nPeriods + '\n';
            txt += 'Avg removed/pixel: ' + safeToFixed(stats['periods_removed_mean'], 1) + '\n';
            txt += 'Max removed/pixel: ' + safeToFixed(stats['periods_removed_max'], 0);
            rainResults.setValue(txt);
            rainStatus.setValue('Diagnostic complete');
            
            Map.addLayer(removedCount.updateMask(comprehensiveMask), {
                min: 0, max: Math.ceil(nPeriods * 0.4),
                palette: ['white', 'yellow', 'orange', 'red', 'darkred']
            }, 'Periods Removed (Rain)', false);
        });
    });
});


//19: METHOD 1 EVENT HANDLERS
m1Step1Btn.onClick(function() {
    var yr = parseInt(yearSelect.getValue());
    m1Status.setValue('Loading...');
    globalStatusLabel.setValue('M1: Loading data for ' + yr + '...');
    
    if (globalCache.year === yr && globalCache.filledSIComposites) {
        m1Status.setValue('Data cached, verifying...');
        globalCache.filledSIComposites.first().bandNames().evaluate(function(bands, error) {
            if (error) {
                m1Status.setValue('Cache invalid, reloading...');
                clearCache();
                globalCache.year = yr;
                var baseData2 = computeBaseData(yr, function(msg) { m1Status.setValue(msg); });
                globalCache.filledSIComposites = baseData2.filledSIComposites;
                globalCache.s2WithAllIndices = baseData2.s2WithAllIndices;
                globalCache.s2ObsDensity = baseData2.s2ObsDensity;
                globalCache.doyList = baseData2.doyList;
                globalCache.startDateEE = baseData2.startDateEE;
                globalCache.periodSeq = baseData2.periodSeq;
                globalCache.modis = baseData2.modis;
                globalCache.rawSIComposites = baseData2.rawSIComposites; 
                m1Status.setValue('Data reloaded');
                globalStatusLabel.setValue('M1 Step 1: Reloaded');
                return;
            }
            m1Status.setValue('Data cached (verified)');
            globalStatusLabel.setValue('M1 Step 1: Using cache');
        });
        return;
    }
    
    clearCache();
    globalCache.year = yr;
    var baseData =computeBaseData(yr, function(msg) { m1Status.setValue(msg); });
    globalCache.filledSIComposites = baseData.filledSIComposites;
    globalCache.s2WithAllIndices = baseData.s2WithAllIndices;
    globalCache.s2ObsDensity = baseData.s2ObsDensity;
    globalCache.doyList = baseData.doyList;
    globalCache.startDateEE = baseData.startDateEE;
    globalCache.periodSeq = baseData.periodSeq;
    globalCache.modis = baseData.modis;
    globalCache.rawSIComposites = baseData.rawSIComposites;    
    globalCache.s2ValidObsMasks = baseData.s2ValidObsMasks;    

    m1Status.setValue('Verifying on server...');
    globalCache.filledSIComposites.first().bandNames().evaluate(function(bands, error) {
        if (error) {
            m1Status.setValue('ERROR: Load failed - ' + error);
            globalStatusLabel.setValue('M1 Step 1: FAILED');
            return;
        }
        m1Status.setValue('Data loaded (verified)');
        globalStatusLabel.setValue('M1 Step 1: Complete');
    });
});

