// 12.5d: Table IV — 多指数分离度对比
// ──────────────────────────────────────────────────────────────────────────
function computeMultiBandSeparability(images, bandNames, labels, cottonSamplesFC, otherSamplesFC) {
    var nItems = images.length;
    var results = [];
    var completed = 0;

    for (var i = 0; i < nItems; i++) {
        (function(idx) {
            var sep = computeSeparability(images[idx], bandNames[idx], cottonSamplesFC, otherSamplesFC);
            sep.M.evaluate(function(m) {
                sep.JM.evaluate(function(jm) {
                    results[idx] = {label: labels[idx], M: m, JM: jm};
                    completed++;
                    if (completed === nItems) {
                        var txt = '\n=== Table IV: Separability ===\n';
                        txt += 'Index      |   M    |   JM\n';
                        txt += '-----------|--------|------\n';
                        var chartRows = [['Index', 'M', 'JM']];
                        for (var j = 0; j < nItems; j++) {
                            txt += padRight(results[j].label, 11) + '| ' +
                                padLeft(safeToFixed(results[j].M, 2), 6) + ' | ' +
                                safeToFixed(results[j].JM, 2) + '\n';
                            chartRows.push([results[j].label, results[j].M, results[j].JM]);
                        }
                        print(txt);

                        var chart = ui.Chart(chartRows, 'ColumnChart', {
                            title: 'Separability by Index',
                            hAxis: {title: ''},
                            vAxis: {title: 'Value', minValue: 0},
                            colors: ['#E53935', '#1E88E5'],
                            legend: {position: 'top'},
                            bar: {groupWidth: '60%'}
                        });
                        print(chart);
                    }
                });
            });
        })(i);
    }
}


