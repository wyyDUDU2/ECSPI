function exportTiledSingleAsset(classImage, description, assetId, region, nCols, nRows) {
    nCols = nCols || 3;
    nRows = nRows || 2;
    var bounds = region.bounds().coordinates().get(0);
    var coords = ee.List(bounds);
    var xMin = ee.Number(ee.List(coords.get(0)).get(0));
    var yMin = ee.Number(ee.List(coords.get(0)).get(1));
    var xMax = ee.Number(ee.List(coords.get(2)).get(0));
    var yMax = ee.Number(ee.List(coords.get(2)).get(1));
    var dx = xMax.subtract(xMin).divide(nCols);
    var dy = yMax.subtract(yMin).divide(nRows);
    
    var tileImages = ee.List.sequence(0, nCols * nRows - 1).map(function(idx) {
        idx = ee.Number(idx);
        var col = idx.mod(nCols);
        var row = idx.divide(nCols).floor();
        var tileGeom = ee.Geometry.Rectangle([
            xMin.add(dx.multiply(col)), yMin.add(dy.multiply(row)),
            xMin.add(dx.multiply(col.add(1))), yMin.add(dy.multiply(row.add(1)))
        ]);
        return classImage.clip(tileGeom);
    });
    
    var mosaic = ee.ImageCollection.fromImages(tileImages).mosaic();
    Export.image.toAsset({
        image: mosaic,
        description: description,
        assetId: assetId,
        region: region,
        scale: outputScale,
        maxPixels: 1e13,
        shardSize: 256
    });
    print('Tiled export (' + nCols + 'x' + nRows + '): ' + description);
}

// Helper: display accuracy on UI label
function displayAccuracy(resultsLabel, accResult, methodName) {
    accResult.OA.evaluate(function(oa) {
        accResult.kappa.evaluate(function(kap) {
            accResult.f1.evaluate(function(f1v) {
                accResult.precision.evaluate(function(prec) {
                    accResult.recall.evaluate(function(rec) {
                        accResult.confMatrix.array().evaluate(function(mat) {
                            var txt = methodName + ' Accuracy:\n';
                            txt += 'OA: ' + safePercent(oa) + '\n';
                            txt += 'Kappa: ' + safeToFixed(kap, 4) + '\n';
                            txt += 'F1: ' + safePercent(f1v) + '\n';
                            txt += 'UA(Prec): ' + safePercent(prec) + '\n';
                            txt += 'PA(Recall): ' + safePercent(rec) + '\n';
                            if (mat && mat.length >= 2 && mat[0] && mat[1]) {
                                var TN = (mat[0][0] !== null && mat[0][0] !== undefined) ? mat[0][0] : 0;
                                var FP = (mat[0][1] !== null && mat[0][1] !== undefined) ? mat[0][1] : 0;
                                var FN = (mat[1][0] !== null && mat[1][0] !== undefined) ? mat[1][0] : 0;
                                var TP = (mat[1][1] !== null && mat[1][1] !== undefined) ? mat[1][1] : 0;
                                txt += 'CM: TN=' + TN + ' FP=' + FP;
                                txt += ' FN=' + FN + ' TP=' + TP;
                            }
                            resultsLabel.setValue(txt);
                            print(txt);
                        });
                    });
                });
            });
        });
    });
}

