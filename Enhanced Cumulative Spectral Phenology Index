function computeCottonAreaKm2(classImage, region) {
    var areaImage = classImage.unmask(0).multiply(ee.Image.pixelArea()).divide(1e6);
    return areaImage.reduceRegion({
        reducer: ee.Reducer.sum(),
        geometry: region,
        scale: analysisScale,
        maxPixels: 1e13,
        bestEffort: true,
        tileScale: tileScale
    });
}




//13: SAFE FORMAT HELPER

function safeToFixed(value, digits) {
    if (value === null || value === undefined || typeof value !== 'number' || isNaN(value)) {
        return 'N/A';
    }
    return value.toFixed(digits);
}

function safePercent(value) {
    if (value === null || value === undefined || typeof value !== 'number' || isNaN(value)) {
        return 'N/A';
    }
    return (value * 100).toFixed(2) + '%';
}



