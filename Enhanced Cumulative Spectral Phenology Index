m1AccuracyBtn.onClick(function() {
    if (!globalCache.result_m1) {
        m1Status.setValue('ERROR: Run classification first!');
        return;
    }
    
    var yr = parseInt(yearSelect.getValue());
    if (yearsWithReference.indexOf(yr) === -1) {
        m1Status.setValue('No reference for ' + yr);
        m1Results.setValue('Accuracy: N/A');
        return;
    }
    
    m1Status.setValue('Evaluating...');
    globalStatusLabel.setValue('M1: Accuracy evaluation...');
    
    var accResult = evaluateAccuracy(globalCache.result_m1, testSamples, 'cotton_csp_s2');
    
    // 用M1独立缓存计算分离度
    var cspForSep = globalCache.CSP_s2only_m1 || globalCache.CSP_s2only;
    if (!cspForSep) {
        displayAccuracy(m1Results, accResult, 'M1 CSP S2');
        m1Status.setValue('Accuracy complete (no CSP for separability)');
        return;
    }
    
    var sep = computeSeparability(cspForSep, 'CSP_s2only', cottonSamples, otherSamples);
    
    // 等accuracy和separability全部完成后一次性写入，避免多次追加
    var accDone = false, sepDone = false;
    var accTxt = '', mVal = null, jmVal = null;
    
    function tryWriteAll() {
        if (!accDone || !sepDone) return;
        var finalTxt = accTxt;
        finalTxt += '\nM-index: ' + safeToFixed(mVal, 4);
        finalTxt += '\nJM-index: ' + safeToFixed(jmVal, 4);
        m1Results.setValue(finalTxt);
        print(finalTxt);
        m1Status.setValue('Accuracy complete');
        globalStatusLabel.setValue('M1: Accuracy done');
    }
    
    // 收集accuracy文本
    accResult.OA.evaluate(function(oa) {
        accResult.kappa.evaluate(function(kap) {
            accResult.f1.evaluate(function(f1v) {
                accResult.precision.evaluate(function(prec) {
                    accResult.recall.evaluate(function(rec) {
                        accResult.confMatrix.array().evaluate(function(mat) {
                            var txt = 'M1 CSP S2 Accuracy:\n';
                            txt += 'OA: ' + safePercent(oa) + '\n';
                            txt += 'Kappa: ' + safeToFixed(kap, 4) + '\n';
                            txt += 'F1: ' + safePercent(f1v) + '\n';
                            txt += 'UA(Prec): ' + safePercent(prec) + '\n';
                            txt += 'PA(Recall): ' + safePercent(rec) + '\n';
                            if (mat && mat.length >= 2 && mat[0] && mat[1]) {
                                var TN = mat[0][0] || 0, FP = mat[0][1] || 0;
                                var FN = mat[1][0] || 0, TP = mat[1][1] || 0;
                                txt += 'CM: TN=' + TN + ' FP=' + FP + ' FN=' + FN + ' TP=' + TP;
                            }
                            accTxt = txt;
                            accDone = true;
                            tryWriteAll();
                        });
                    });
                });
            });
        });
    });
    
    sep.M.evaluate(function(m) {
        mVal = m;
        sep.JM.evaluate(function(jm) {
            jmVal = jm;
            sepDone = true;
            tryWriteAll();
        });
    });
});

