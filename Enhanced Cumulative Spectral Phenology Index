//5: CORE PROCESSING FUNCTIONS

// Cloud masking
function maskS2Clouds(image) {
    var qa = image.select('QA60');
    var cloudBitMask = 1 << 10;
    var cirrusBitMask = 1 << 11;
    
    var qaMask = qa.bitwiseAnd(cloudBitMask).eq(0)
        .and(qa.bitwiseAnd(cirrusBitMask).eq(0));
    
    var scl = image.select('SCL');
    var sclMask = scl.neq(3).and(scl.neq(8)).and(scl.neq(9))
        .and(scl.neq(10)).and(scl.neq(11));
    
    return image.updateMask(qaMask.and(sclMask))
        .divide(10000)
        .copyProperties(image, ['system:time_start']);
}

// SI calculation
function calculateSI(image) {
    var RE2 = image.select('B6');
    var RE3 = image.select('B7');
    var NIR = image.select('B8');
    var si = RE2.add(RE3).add(NIR).float().rename('SI');
    
    var date = ee.Date(image.get('system:time_start'));
    var doy = date.getRelative('day', 'year');
    
    return image.addBands(si)
        .set('DOY', doy)
        .set('date', date.format('YYYY-MM-dd'));
}

// All indices
function addAllIndices(image) {
    var RE2 = image.select('B6');
    var RE3 = image.select('B7');
    var NIR = image.select('B8');
    var RED = image.select('B4');
    var BLUE = image.select('B2');
    var GREEN = image.select('B3');
    var SWIR1 = image.select('B11');
    
    var si = RE2.add(RE3).add(NIR).float().rename('SI');
    var ndvi = NIR.subtract(RED).divide(NIR.add(RED).add(0.0001)).float().rename('NDVI');
    
    var evi = image.expression(
        '2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))', {
            'NIR': NIR, 'RED': RED, 'BLUE': BLUE
        }).float().rename('EVI');
    
    var lswi = NIR.subtract(SWIR1).divide(NIR.add(SWIR1).add(0.0001)).float().rename('LSWI');
    var ndwi = GREEN.subtract(NIR).divide(GREEN.add(NIR).add(0.0001)).float().rename('NDWI');
    
    var bsi = image.expression(
        '((SWIR1 + RED) - (NIR + BLUE)) / ((SWIR1 + RED) + (NIR + BLUE) + 0.0001)', {
            'SWIR1': SWIR1, 'RED': RED, 'NIR': NIR, 'BLUE': BLUE
        }).float().rename('BSI');
    
    var date = ee.Date(image.get('system:time_start'));
    var doy = date.getRelative('day', 'year');
    
    return image.addBands([si, ndvi, evi, lswi, ndwi, bsi])
        .set('DOY', doy)
        .set('date', date.format('YYYY-MM-dd'));
}

// MODIS processing
function processModis(image) {
    var ndvi = image.select('NDVI').multiply(0.0001).float().rename('MODIS_NDVI');
    var evi = image.select('EVI').multiply(0.0001).float().rename('MODIS_EVI');
    return ndvi.addBands(evi)
        .copyProperties(image, ['system:time_start']);
}

// Temporal statistics
function computeTemporalStats(collection, bandName) {
    var filtered = collection.select(bandName);
    var stats = filtered.reduce(
        ee.Reducer.mean()
            .combine(ee.Reducer.min(), null, true)
            .combine(ee.Reducer.max(), null, true)
            .combine(ee.Reducer.stdDev(), null, true)
    );
    return stats.rename([
        bandName + '_mean', 
        bandName + '_min', 
        bandName + '_max', 
        bandName + '_stdDev'
    ]);
}


function extractIndexPhenology(compositeCollection, bandName, doyList, mask, prefix, invertSign) {
    // A: 间隙填补 — 用时序中位数填充无数据时段
    var temporalMedian = compositeCollection.select(bandName).median();
    var filledCollection = compositeCollection.map(function(img) {
        var val = img.select(bandName).unmask(temporalMedian).float().rename(bandName);
        return val.copyProperties(img, ['system:time_start', 'DOY', 'period_index']);
    });
    
    // B: 构建检测用集合（BSI/NDWI取反使谷变峰）
    var detectionCollection = invertSign ?
        filledCollection.map(function(img) {
            return img.select(bandName).multiply(-1).float().rename(bandName)
                .copyProperties(img, ['system:time_start', 'DOY', 'period_index']);
        }) : filledCollection;
    
    // C: SG平滑
    var smoothedDetection = smoothTimeSeriesPixelWise(detectionCollection, bandName, sgHalfWindow);
    
    // D: 独立T1/T2检测
    var t1t2 = detectPerPixelT1T2(smoothedDetection, bandName, doyList, mask);
    var T1_doy = t1t2.T1_image.rename(prefix + '_T1');
    var T2_doy = t1t2.T2_image.rename(prefix + '_T2');
    
    // E: 在原始值（非取反）上提取T1/T2处的指数值
    var smoothedOrig = invertSign ?
        smoothTimeSeriesPixelWise(filledCollection, bandName, sgHalfWindow) :
        smoothedDetection;
    
    var collList = smoothedOrig.toList(smoothedOrig.size());
    var numPeriods = smoothedOrig.size();
    
    var valAtPoints = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var img = ee.Image(collList.get(i));
            var doyVal = ee.Number(doyList.get(i));
            var doyConst = ee.Image.constant(doyVal).float();
            return img.select(bandName).rename('val')
                .addBands(doyConst.subtract(T1_doy).abs().rename('dist_T1'))
                .addBands(doyConst.subtract(T2_doy).abs().rename('dist_T2'))
                .updateMask(mask);
        })
    );
    
    // qualityMosaic: 距T1/T2最近的时段
    var valT1 = valAtPoints.map(function(img) {
        return img.addBands(img.select('dist_T1').multiply(-1).rename('quality'));
    }).qualityMosaic('quality').select('val').rename(prefix + '_valT1');
    
    var valT2 = valAtPoints.map(function(img) {
        return img.addBands(img.select('dist_T2').multiply(-1).rename('quality'));
    }).qualityMosaic('quality').select('val').rename(prefix + '_valT2');
    
    // F: 衍生物候参数
    var amplitude = valT2.subtract(valT1).rename(prefix + '_amp');       // 增幅
    var duration  = T2_doy.subtract(T1_doy).max(1).rename(prefix + '_dur'); // 生长期长度
    var rate      = amplitude.divide(duration).rename(prefix + '_rate');     // 生长速率
    
    return ee.Image.cat([T1_doy, T2_doy, valT1, valT2, amplitude, duration, rate]).float();
}


function extractIndexPhenologyWithT1T2(compositeCollection, bandName, doyList, mask, prefix, T1_image, T2_image) {
    // A: 间隙填补
    var temporalMedian = compositeCollection.select(bandName).median();
    var filledCollection = compositeCollection.map(function(img) {
        var val = img.select(bandName).unmask(temporalMedian).float().rename(bandName);
        return val.copyProperties(img, ['system:time_start', 'DOY', 'period_index']);
    });
    
    // B: 直接用外部 T1/T2（已 rename）
    var T1_doy = T1_image.rename(prefix + '_T1');
    var T2_doy = T2_image.rename(prefix + '_T2');
    
    // C: 在原始值上提取 T1/T2 处的指数值
    var collList = filledCollection.toList(filledCollection.size());
    var numPeriods = filledCollection.size();
    
    var valAtPoints = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var img = ee.Image(collList.get(i));
            var doyVal = ee.Number(doyList.get(i));
            var doyConst = ee.Image.constant(doyVal).float();
            return img.select(bandName).rename('val')
                .addBands(doyConst.subtract(T1_doy).abs().rename('dist_T1'))
                .addBands(doyConst.subtract(T2_doy).abs().rename('dist_T2'))
                .updateMask(mask);
        })
    );
    
    var valT1 = valAtPoints.map(function(img) {
        return img.addBands(img.select('dist_T1').multiply(-1).rename('quality'));
    }).qualityMosaic('quality').select('val').rename(prefix + '_valT1');
    
    var valT2 = valAtPoints.map(function(img) {
        return img.addBands(img.select('dist_T2').multiply(-1).rename('quality'));
    }).qualityMosaic('quality').select('val').rename(prefix + '_valT2');
    
    // D: 衍生物候参数
    var amplitude = valT2.subtract(valT1).rename(prefix + '_amp');
    var duration  = T2_doy.subtract(T1_doy).max(1).rename(prefix + '_dur');
    var rate      = amplitude.divide(duration).rename(prefix + '_rate');
    
    return ee.Image.cat([T1_doy, T2_doy, valT1, valT2, amplitude, duration, rate]).float();
}

// ── 批量提取: 多指数共享 T1/T2，一次遍历 + 一次 mosaic ──
function extractBatchPhenologyWithSharedT1T2(
    compositeCollection, bandNames, doyList, mask, T1_image, T2_image
) {
    // A: 统一间隙填补（所有波段一起，只遍历一次）
    var medians = {};
    for (var b = 0; b < bandNames.length; b++) {
        medians[bandNames[b]] = compositeCollection.select(bandNames[b]).median();
    }
    
    var filledCollection = compositeCollection.map(function(img) {
        var filledBands = bandNames.map(function(band) {
            return img.select(band).unmask(medians[band]).float().rename(band);
        });
        return ee.Image.cat(filledBands)
            .copyProperties(img, ['system:time_start', 'DOY', 'period_index']);
    });
    
    // B: 统一构建值提取集合（只遍历一次，携带所有波段）
    var collList = filledCollection.toList(filledCollection.size());
    var numPeriods = filledCollection.size();
    var T1_doy = T1_image.float();
    var T2_doy = T2_image.float();
    
    var valAtPoints = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var img = ee.Image(collList.get(i));
            var doyVal = ee.Number(doyList.get(i));
            var doyConst = ee.Image.constant(doyVal).float();
            return img.select(bandNames)
                .addBands(doyConst.subtract(T1_doy).abs().rename('dist_T1'))
                .addBands(doyConst.subtract(T2_doy).abs().rename('dist_T2'))
                .updateMask(mask);
        })
    );
    
    // C: 一次 qualityMosaic 同时提取所有指数的 T1 值
    var mosaicT1 = valAtPoints.map(function(img) {
        return img.addBands(img.select('dist_T1').multiply(-1).rename('quality'));
    }).qualityMosaic('quality');
    
    // 一次 qualityMosaic 同时提取所有指数的 T2 值
    var mosaicT2 = valAtPoints.map(function(img) {
        return img.addBands(img.select('dist_T2').multiply(-1).rename('quality'));
    }).qualityMosaic('quality');
    
    // D: 组装每个指数的 7 个物候波段（T1/T2/dur 只是 rename，不增加计算图深度）
    var duration = T2_doy.subtract(T1_doy).max(1).float();
    
    var resultBands = [];
    for (var b = 0; b < bandNames.length; b++) {
        var band = bandNames[b];
        var vT1 = mosaicT1.select(band).rename(band + '_valT1');
        var vT2 = mosaicT2.select(band).rename(band + '_valT2');
        var amp = vT2.subtract(vT1).rename(band + '_amp');
        var rate = amp.divide(duration).rename(band + '_rate');
        
        resultBands.push(T1_doy.rename(band + '_T1'));
        resultBands.push(T2_doy.rename(band + '_T2'));
        resultBands.push(vT1);
        resultBands.push(vT2);
        resultBands.push(amp);
        resultBands.push(duration.rename(band + '_dur'));
        resultBands.push(rate);
    }
    
    return ee.Image.cat(resultBands).float();
}


//6: OTSU THRESHOLD 


function computeOtsuThresholdClientSide(cspImage, mask, bandName) {
    var maskedCSP = cspImage.updateMask(mask);
    
    var histogram = maskedCSP.reduceRegion({
        reducer: ee.Reducer.histogram({
            maxBuckets: 128,  
            minBucketWidth: 0.002
        }),
        geometry: studyArea,
        scale: analysisScale,
        maxPixels: 1e13,
        bestEffort: true,
        tileScale: tileScale
    });
    
    var histDict = ee.Dictionary(histogram.get(bandName));
    var counts = ee.Array(histDict.get('histogram'));
    var means = ee.Array(histDict.get('bucketMeans'));
    
    var total = counts.reduce(ee.Reducer.sum(), [0]).get([0]);
    var sum = counts.multiply(means).reduce(ee.Reducer.sum(), [0]).get([0]);
    var globalMean = ee.Number(sum).divide(ee.Number(total).max(1));
    
    var size = counts.length().get([0]);
    var indices = ee.List.sequence(0, ee.Number(size).subtract(1));
    
    var result = indices.iterate(function(i, acc) {
        var accDict = ee.Dictionary(acc);
        var idx = ee.Number(i);
        
        var count_i = counts.get([idx]);
        var mean_i = means.get([idx]);
        
        var wB = accDict.getNumber('wB').add(count_i);
        var sumB = accDict.getNumber('sumB').add(ee.Number(count_i).multiply(mean_i));
        var wF = ee.Number(total).subtract(wB);
        
        var mB = ee.Number(ee.Algorithms.If(wB.gt(0), sumB.divide(wB), 0));
        var mF = ee.Number(ee.Algorithms.If(wF.gt(0), 
            ee.Number(sum).subtract(sumB).divide(wF.max(1)), 0));
        
        var varBetween = wB.multiply(wF).multiply(mB.subtract(mF).pow(2));
        
        var maxVar = accDict.getNumber('maxVar');
        var bestThresh = accDict.getNumber('bestThresh');
        
        var newMaxVar = ee.Number(ee.Algorithms.If(varBetween.gt(maxVar), varBetween, maxVar));
        var newBestThresh = ee.Number(ee.Algorithms.If(varBetween.gt(maxVar), mean_i, bestThresh));
        
        return ee.Dictionary({
            'wB': wB,
            'sumB': sumB,
            'maxVar': newMaxVar,
            'bestThresh': newBestThresh
        });
    }, ee.Dictionary({
        'wB': 0,
        'sumB': 0,
        'maxVar': 0,
        'bestThresh': globalMean
    }));
    
    return ee.Dictionary(result).getNumber('bestThresh');
}


//7: SAUVOLA LOCAL THRESHOLD 

function applySauvolaThresholdAsync(cspImage, globalOtsuThresh, k, mask) {
    var maskedCSP = cspImage.updateMask(mask);
    var kernelRadiusPixels = Math.min(Math.ceil(sauvolaWindowSize / outputScale), 15);
    
    var localMean = maskedCSP.reduceNeighborhood({
        reducer: ee.Reducer.mean(),
        kernel: ee.Kernel.square(kernelRadiusPixels, 'pixels'),
        skipMasked: true
    }).rename('localMean');
    
    var localStd = maskedCSP.reduceNeighborhood({
        reducer: ee.Reducer.stdDev(),
        kernel: ee.Kernel.square(kernelRadiusPixels, 'pixels'),
        skipMasked: true
    }).rename('localStd');
    
    var globalStdDict = maskedCSP.reduceRegion({
        reducer: ee.Reducer.stdDev(),
        geometry: studyArea,
        scale: analysisScale,
        maxPixels: 1e13,
        bestEffort: true,
        tileScale: tileScale
    });
    
    var R = ee.Number(globalStdDict.values().get(0)).max(0.001);
    
    var localThreshold = localMean.multiply(
        ee.Image.constant(1).add(
            ee.Image.constant(k).multiply(
                localStd.divide(R).subtract(1)
            )
        )
    ).rename('localThreshold');
    
    var finalThreshold = localThreshold.where(
        localThreshold.lt(globalOtsuThresh),
        globalOtsuThresh
    ).rename('finalThreshold');
    
    return finalThreshold.updateMask(mask);
}

//8: TIME SERIES SMOOTHING — Savitzky-Golay Filter

function smoothTimeSeriesPixelWise(collection, bandName, halfWindow) {
    var collList = collection.toList(collection.size());
    var numImages = collection.size();
    
    // ── Savitzky-Golay 二阶多项式系数 ──
    // 根据 halfWindow 选取对应的归一化系数
    var sgCoeffsLookup = {
        1: [1/3, 1/3, 1/3],                                           // 3点: 回退为均值
        2: [-3/35, 12/35, 17/35, 12/35, -3/35],                       // 5点
        3: [-2/21, 3/21, 6/21, 7/21, 6/21, 3/21, -2/21],             // 7点
        4: [-21/231, 14/231, 39/231, 54/231, 59/231,                  // 9点
            54/231, 39/231, 14/231, -21/231]
    };
    
    var hw = Math.min(Math.max(halfWindow, 1), 4);
    var coeffsArray = sgCoeffsLookup[hw];
    var windowSize = coeffsArray.length;
    var sgCoeffs = ee.List(coeffsArray);
    
    var smoothed = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numImages.subtract(1)).map(function(idx) {
            idx = ee.Number(idx);
            var centerImg = ee.Image(collList.get(idx));
            
            // 构建窗口索引，边界用 clamp（最近邻镜像）
            // j 从 0 到 windowSize-1，对应偏移 -halfWindow 到 +halfWindow
            var weightedImages = ee.List.sequence(0, windowSize - 1).map(function(j) {
                j = ee.Number(j);
                var srcIdx = idx.subtract(hw).add(j);
                // Clamp: 超出 [0, numImages-1] 范围时取边界值
                var clampedIdx = srcIdx.max(0).min(numImages.subtract(1));
                var coeff = ee.Number(sgCoeffs.get(j));
                return ee.Image(collList.get(clampedIdx))
                    .select(bandName)
                    .multiply(coeff)
                    .float();
            });
            
            // SG 滤波值 = 加权求和
            var sgValue = ee.ImageCollection.fromImages(weightedImages)
                .sum()
                .float()
                .rename(bandName);
            
            // 安全回退：若 SG 值无效则保留原始值
            var original = centerImg.select(bandName).float();
            sgValue = sgValue.unmask(original);
            
            return sgValue.copyProperties(centerImg, 
                ['system:time_start', 'DOY', 'period_index']);
        })
    );
    
    return smoothed;
}

//9: PER-PIXEL T1/T2 DETECTION 

function detectPerPixelT1T2(smoothedCollection, bandName, doyList, mask) {
    var collList = smoothedCollection.toList(smoothedCollection.size());
    var numPeriods = smoothedCollection.size();
    
    // Build SI band stack (V6.0: optimized for memory)
    var siImages = ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
        var img = ee.Image(collList.get(i)).select(bandName).float();
        return img.rename(ee.String('b').cat(ee.Number(i).int().format()));
    });
    
    var stack = ee.ImageCollection.fromImages(siImages).toBands();
    
    // Fix band names
    var currentNames = stack.bandNames();
    var newNames = currentNames.map(function(name) {
        return ee.String(name).split('_').get(-1);
    });
    stack = stack.rename(newNames).updateMask(mask);
    
    // DOY band stack
    var doyImages = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            var doyVal = ee.Number(doyList.get(i));
            var bName = ee.String('b').cat(ee.Number(i).int().format());
            return ee.Image.constant(doyVal).float().rename(bName);
        })
    ).toBands();
    
    var doyCurrentNames = doyImages.bandNames();
    var doyNewNames = doyCurrentNames.map(function(name) {
        return ee.String(name).split('_').get(-1);
    });
    doyImages = doyImages.rename(doyNewNames);
    
    // T2: Maximum SI DOY (per-pixel)
    var maxSI = stack.reduce(ee.Reducer.max());
    var isMax = stack.eq(maxSI);
    var T2_doy_image = doyImages.multiply(isMax).reduce(ee.Reducer.max()).rename('T2_DOY');
    
    // First derivative (per-pixel) 
    var numDiffs = numPeriods.subtract(1);
    var firstDiffImages = ee.List.sequence(0, numDiffs.subtract(1)).map(function(i) {
        i = ee.Number(i);
        var bCurr = ee.String('b').cat(i.int().format());
        var bNext = ee.String('b').cat(i.add(1).int().format());
        var diff = stack.select(bNext).subtract(stack.select(bCurr)).float();
        return diff.rename(ee.String('d').cat(i.int().format()));
    });
    
    var firstDiffStack = ee.ImageCollection.fromImages(firstDiffImages).toBands();
    var fdCurrentNames = firstDiffStack.bandNames();
    var fdNewNames = fdCurrentNames.map(function(name) {
        return ee.String(name).split('_').get(-1);
    });
    firstDiffStack = firstDiffStack.rename(fdNewNames);
    
    // Second derivative
    var numAccels = numPeriods.subtract(2);
    var secondDiffImages = ee.List.sequence(0, numAccels.subtract(1)).map(function(i) {
        i = ee.Number(i);
        var dCurr = ee.String('d').cat(i.int().format());
        var dNext = ee.String('d').cat(i.add(1).int().format());
        var accel = firstDiffStack.select(dNext).subtract(firstDiffStack.select(dCurr)).float();
        return accel.rename(ee.String('a').cat(i.int().format()));
    });
    
    var accelStack = ee.ImageCollection.fromImages(secondDiffImages).toBands();
    var acCurrentNames = accelStack.bandNames();
    var acNewNames = acCurrentNames.map(function(name) {
        return ee.String(name).split('_').get(-1);
    });
    accelStack = accelStack.rename(acNewNames);
    
    // DOY for accelerations
    var accelDoyImages = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numAccels.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var doyVal = ee.Number(doyList.get(i.add(1)));
            return ee.Image.constant(doyVal).float()
                .rename(ee.String('a').cat(i.int().format()));
        })
    ).toBands();
    
    var adCurrentNames = accelDoyImages.bandNames();
    var adNewNames = adCurrentNames.map(function(name) {
        return ee.String(name).split('_').get(-1);
    });
    accelDoyImages = accelDoyImages.rename(adNewNames);
    
    // Mask: before T2 and in reasonable T1 range (per-pixel)
    var beforeT2Mask = accelDoyImages.lt(T2_doy_image);
    var reasonableT1Mask = accelDoyImages.gte(90).and(accelDoyImages.lte(180));
    var maskedAccel = accelStack.updateMask(beforeT2Mask.and(reasonableT1Mask));
    
    // T1: Maximum acceleration DOY (per-pixel)
    var maxAccel = maskedAccel.reduce(ee.Reducer.max());
    var isMaxAccel = maskedAccel.eq(maxAccel);
    var maskedAccelDoy = accelDoyImages.updateMask(beforeT2Mask.and(reasonableT1Mask));
    var T1_doy_image = maskedAccelDoy.multiply(isMaxAccel).reduce(ee.Reducer.max()).rename('T1_DOY');
    
    // Validation and fallback (per-pixel)
    var T1_valid = T1_doy_image.gte(90).and(T1_doy_image.lte(170)).and(T1_doy_image.lt(T2_doy_image));
    var T2_valid = T2_doy_image.gte(160).and(T2_doy_image.lte(260));
    
    var T1_final = T1_doy_image.where(T1_valid.not(), T1_DOY_default)
        .where(T2_valid.not(), T1_DOY_default)
        .rename('T1_DOY').float();
    
    var T2_final = T2_doy_image.where(T2_valid.not(), T2_DOY_default)
        .rename('T2_DOY').float();
    
    // Ensure T1 < T2 (per-pixel)
    var needSwap = T1_final.gte(T2_final);
    T1_final = T1_final.where(needSwap, T1_DOY_default);
    T2_final = T2_final.where(needSwap, T2_DOY_default);
    
    return {
        T1_image: T1_final.updateMask(mask),
        T2_image: T2_final.updateMask(mask)
    };
}

//10: PER-PIXEL CSP COMPUTATION 

function computePerPixelCSP(filledCollection, T1_image, T2_image, doyList, mask) {
    var collList = filledCollection.toList(filledCollection.size());
    var numPeriods = filledCollection.size();
    
    // Growth period cumulative SI and period count (per-pixel)
    var growthMasked = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var img = ee.Image(collList.get(i));
            var doyVal = ee.Number(doyList.get(i));
            var doyConst = ee.Image.constant(doyVal).float();
            
            // Per-pixel growth period check
            var inGrowth = doyConst.gte(T1_image).and(doyConst.lte(T2_image));
            
            return img.select('SI_filled').float().updateMask(inGrowth).updateMask(mask)
                .addBands(ee.Image.constant(1).float().rename('count').updateMask(inGrowth).updateMask(mask));
        })
    );
    
    var cumulativeSI = growthMasked.select('SI_filled').sum().rename('cumulative_SI');
    var periodCount = growthMasked.select('count').sum().rename('n_periods');
    
    // Use qualityMosaic to get SI at T1 and T2 (per-pixel)
    var siAtT1T2 = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var img = ee.Image(collList.get(i));
            var doyVal = ee.Number(doyList.get(i));
            var doyConst = ee.Image.constant(doyVal).float();
            
            var distToT1 = doyConst.subtract(T1_image).abs().float().rename('dist_T1');
            var distToT2 = doyConst.subtract(T2_image).abs().float().rename('dist_T2');
            
            return img.select('SI_filled').float().rename('SI_val')
                .addBands(distToT1)
                .addBands(distToT2)
                .updateMask(mask);
        })
    );
    
    // Get closest SI to T1 (per-pixel)
    var forT1 = siAtT1T2.map(function(img) {
        var negDist = img.select('dist_T1').multiply(-1).rename('quality');
        return img.addBands(negDist);
    });
    var SI_at_T1 = forT1.qualityMosaic('quality').select('SI_val').rename('SI_T1');
    
    // Get closest SI to T2 (per-pixel)
    var forT2 = siAtT1T2.map(function(img) {
        var negDist = img.select('dist_T2').multiply(-1).rename('quality');
        return img.addBands(negDist);
    });
    var SI_at_T2 = forT2.qualityMosaic('quality').select('SI_val').rename('SI_T2');
    
    // CSP = slope * cumulative_SI (per-pixel)
    var safePeriodCount = periodCount.max(1);
    var slope = SI_at_T2.subtract(SI_at_T1).divide(safePeriodCount).rename('slope');
    var cspRaw = slope.multiply(cumulativeSI);
    
    // 归一化：消除有效周期数差异对CSP的影响
    // CSP = slope × cumSI / n × n_ref（n_ref为参考周期数，保持量纲一致）
    var n_ref = T2_image.subtract(T1_image).divide(compositePeriod).max(1).rename('n_ref');
    var csp = cspRaw.divide(safePeriodCount).multiply(n_ref).rename('CSP');
    
    return csp.updateMask(mask);
}

function computePerPixelCSPFull(filledCollection, T1_image, T2_image, doyList, mask) {
    var collList = filledCollection.toList(filledCollection.size());
    var numPeriods = filledCollection.size();
    
    var growthMasked = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var img = ee.Image(collList.get(i));
            var doyVal = ee.Number(doyList.get(i));
            var doyConst = ee.Image.constant(doyVal).float();
            var inGrowth = doyConst.gte(T1_image).and(doyConst.lte(T2_image));
            return img.select('SI_filled').float().updateMask(inGrowth).updateMask(mask)
                .addBands(ee.Image.constant(1).float().rename('count').updateMask(inGrowth).updateMask(mask));
        })
    );
    
    var cumulativeSI = growthMasked.select('SI_filled').sum().rename('cumulative_SI');
    var periodCount = growthMasked.select('count').sum().rename('n_periods');
    
    var siAtT1T2 = ee.ImageCollection.fromImages(
        ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var img = ee.Image(collList.get(i));
            var doyVal = ee.Number(doyList.get(i));
            var doyConst = ee.Image.constant(doyVal).float();
            var distToT1 = doyConst.subtract(T1_image).abs().float().rename('dist_T1');
            var distToT2 = doyConst.subtract(T2_image).abs().float().rename('dist_T2');
            return img.select('SI_filled').float().rename('SI_val')
                .addBands(distToT1).addBands(distToT2).updateMask(mask);
        })
    );
    
    var SI_at_T1 = siAtT1T2.map(function(img) {
        return img.addBands(img.select('dist_T1').multiply(-1).rename('quality'));
    }).qualityMosaic('quality').select('SI_val').rename('SI_T1');
    
    var SI_at_T2 = siAtT1T2.map(function(img) {
        return img.addBands(img.select('dist_T2').multiply(-1).rename('quality'));
    }).qualityMosaic('quality').select('SI_val').rename('SI_T2');
    
    var safePeriodCount = periodCount.max(1);
    var slope = SI_at_T2.subtract(SI_at_T1).divide(safePeriodCount).rename('slope');
    var cspRaw = slope.multiply(cumulativeSI);
    
    var n_ref = T2_image.subtract(T1_image).divide(compositePeriod).max(1).rename('n_ref');
    var csp = cspRaw.divide(safePeriodCount).multiply(n_ref).rename('CSP');
    var meanSI = cumulativeSI.divide(safePeriodCount).rename('cumulative_SI');
    
    return ee.Image.cat([csp, SI_at_T1, SI_at_T2, slope, meanSI])
        .float().updateMask(mask);
}



//11: ADAPTIVE FUSION WEIGHTS — Gap-Aware Strategy (Memory-Optimized)
function computeAdaptiveFusionWeightsPixelWise(csp_s2, csp_modis, s2ObsDensity, mask) {
    var maskedS2 = csp_s2.updateMask(mask);
    var maskedModis = csp_modis.updateMask(mask);
    var obsSource = globalCache.effectiveObsDensity 
        ? globalCache.effectiveObsDensity 
        : s2ObsDensity;
    var maskedObs = obsSource.updateMask(mask);
    
    // ====== 优化1: 预计算百分位数并缓存为常量，避免权重影像引用 reduceRegion 惰性节点 ======
    // 这个 reduceRegion 会在 m2Step5Btn.onClick 中通过 .evaluate() 提前求值
    // 这里只构建影像计算图，不触发 reduceRegion
    
    var obsP10 = ee.Number(globalCache._obsPercentiles ? globalCache._obsPercentiles.p10 : 1).max(1);
    var obsP90 = ee.Number(globalCache._obsPercentiles ? globalCache._obsPercentiles.p90 : 3).max(3);
    
    // ====== Component 1: Temporal Gap Severity ======
    var obsNormalized = maskedObs.subtract(obsP10).divide(obsP90.subtract(obsP10).max(1)).clamp(0, 1);
    
    var sigmoid_k = 8;
    var sigmoid_x0 = 0.4;
    var gapScore = ee.Image.constant(1).divide(
        ee.Image.constant(1).add(
            obsNormalized.subtract(sigmoid_x0).multiply(-sigmoid_k).exp()
        )
    ).rename('gap_score');
    
    // ====== Component 2: Local Spatial Coherence (优化: 降低kernel到3像素) ======
    // 3×3 kernel 的 reduceNeighborhood 比 5×5 内存低 ~2.8倍，效果差异极小
    var localKernel = ee.Kernel.square(3, 'pixels');
    
    var s2LocalMean = maskedS2.reduceNeighborhood({
        reducer: ee.Reducer.mean(), kernel: localKernel, skipMasked: true
    });
    var s2LocalStd = maskedS2.reduceNeighborhood({
        reducer: ee.Reducer.stdDev(), kernel: localKernel, skipMasked: true
    });
    
    var s2Deviation = maskedS2.subtract(s2LocalMean).abs()
        .divide(s2LocalStd.max(0.001));
    var s2LocalConfidence = ee.Image.constant(1).divide(
        ee.Image.constant(1).add(s2Deviation)
    ).rename('s2_confidence');
    
    // ====== Component 3: S2-MODIS Consistency (优化: 合并reduceNeighborhood) ======
    // 原来: 4次独立的 reduceNeighborhood (s2 p50, modis p50, signAgreement mean, 各用不同kernel)
    // 优化: 用相同的小kernel一次性计算局部均值代替percentile50（均值≈中位数，对连续CSP值差异极小）
    //       同时将 signAgreement 的局部均值与 s2 局部统计共享 kernel 尺寸
    
    var modisLocalMean = maskedModis.reduceNeighborhood({
        reducer: ee.Reducer.mean(), kernel: localKernel, skipMasked: true
    });
    
    // 用局部均值代替局部中位数（避免额外2次 reduceNeighborhood）
    var s2Sign = maskedS2.subtract(s2LocalMean);
    var modisSign = maskedModis.subtract(modisLocalMean);
    var signAgreement = s2Sign.multiply(modisSign).gt(0).float();
    
    // 用同一个 kernel 计算局部一致率
    var consistencyScore = signAgreement.reduceNeighborhood({
        reducer: ee.Reducer.mean(),
        kernel: localKernel,
        skipMasked: true
    }).rename('consistency');
    
    var w_s2 = gapScore.multiply(0.70)
    .add(s2LocalConfidence.multiply(0.15))
    .add(consistencyScore.multiply(0.15))
    .clamp(0.3, 0.95)
    .rename('w_s2');
    
    // Safety: 极端缺失区域
    var extremeGap = maskedObs.lt(obsP10);
    w_s2 = w_s2.where(extremeGap, w_s2.min(0.5));
    
    return w_s2.updateMask(mask);
}



// ── 11b: GROWTH-PERIOD OBSERVATION COVERAGE ──
function computeGrowthPeriodObsDensity(T1_image, T2_image, mask) {
    var s2ValidObsMasks = globalCache.s2ValidObsMasks;
    var obsList = s2ValidObsMasks.toList(s2ValidObsMasks.size());
    var numPeriods = s2ValidObsMasks.size();
    var doyList = globalCache.doyList;
    
    var useRainMask = rainCorrectionApplied && globalCache.rainQualityMask;
    var rainMaskList = useRainMask
        ? globalCache.rainQualityMask.toList(globalCache.rainQualityMask.size())
        : null;
    
    var growthObsImages;
    if (useRainMask) {
        growthObsImages = ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var obsImg = ee.Image(obsList.get(i));
            var rainImg = ee.Image(rainMaskList.get(i)).select('reliable');
            var doy = ee.Number(doyList.get(i));
            var doyImg = ee.Image.constant(doy).float();
            var inGrowth = doyImg.gte(T1_image).and(doyImg.lte(T2_image));
            var obs = obsImg.select('has_real_obs').float().multiply(rainImg);
            return obs.multiply(inGrowth.float()).rename('gp_obs');
        });
    } else {
        growthObsImages = ee.List.sequence(0, numPeriods.subtract(1)).map(function(i) {
            i = ee.Number(i);
            var obsImg = ee.Image(obsList.get(i));
            var doy = ee.Number(doyList.get(i));
            var doyImg = ee.Image.constant(doy).float();
            var inGrowth = doyImg.gte(T1_image).and(doyImg.lte(T2_image));
            var obs = obsImg.select('has_real_obs').float();
            return obs.multiply(inGrowth.float()).rename('gp_obs');
        });
    }
    
    var actualObs = ee.ImageCollection.fromImages(growthObsImages)
        .sum().rename('gp_obs_count');
    var expectedPeriods = T2_image.subtract(T1_image)
        .divide(compositePeriod).max(1).rename('gp_expected');
    var coverageRatio = actualObs.divide(expectedPeriods)
        .clamp(0, 1).rename('gp_coverage');
    
    return ee.Image.cat([actualObs, coverageRatio]).float().updateMask(mask);
}





//12: ACCURACY EVALUATION

function evaluateAccuracy(classificationResult, testSamplesFC, bandName) {
    // 用 unmask(0) + sampleRegions(scale=30) 降低内存
    var predicted = classificationResult.unmask(0).rename('predicted');
    
    // 分 batch 采样后合并，避免单次 sampleRegions 超限
    var nBatches = 4;
    var withBatch = testSamplesFC.randomColumn('_evalBatch', 9999);
    var batchResults = [];
    
    for (var b = 0; b < nBatches; b++) {
        var lo = b / nBatches;
        var hi = (b + 1) / nBatches;
        var batchFilter;
        if (b === 0) {
            batchFilter = ee.Filter.lt('_evalBatch', hi);
        } else if (b === nBatches - 1) {
            batchFilter = ee.Filter.gte('_evalBatch', lo);
        } else {
            batchFilter = ee.Filter.and(
                ee.Filter.gte('_evalBatch', lo),
                ee.Filter.lt('_evalBatch', hi)
            );
        }
        
        batchResults.push(
            predicted.sampleRegions({
                collection: withBatch.filter(batchFilter),
                properties: ['class'],
                scale: 10,        
                tileScale: 16,
                geometries: false
            })
        );
    }
    
    var testData = batchResults[0];
    for (var i = 1; i < batchResults.length; i++) {
        testData = testData.merge(batchResults[i]);
    }
    
    var confMatrix = testData.errorMatrix('class', 'predicted');
    var OA = confMatrix.accuracy();
    var kappa = confMatrix.kappa();
    
    var arr = confMatrix.array();
    var tp = arr.get([1, 1]);
    var fp = arr.get([0, 1]);
    var fn = arr.get([1, 0]);
    var tn = arr.get([0, 0]);
    
    var precision = ee.Number(tp).divide(ee.Number(tp).add(fp).max(1));
    var recall = ee.Number(tp).divide(ee.Number(tp).add(fn).max(1));
    var f1 = ee.Number(2).multiply(precision).multiply(recall)
        .divide(precision.add(recall).max(0.0001));
    
    return {
        confMatrix: confMatrix,
        OA: OA,
        kappa: kappa,
        precision: precision,
        recall: recall,
        f1: f1,
        tp: tp, fp: fp, fn: fn, tn: tn
    };
}

// Separability indices
function computeSeparability(cspImage, bandName, cottonSamplesFC, otherSamplesFC) {
    var cottonCSP = cspImage.sampleRegions({
        collection: cottonSamplesFC,
        properties: ['class'],
        scale: outputScale,
        tileScale: tileScale
    });
    
    var otherCSP = cspImage.sampleRegions({
        collection: otherSamplesFC,
        properties: ['class'],
        scale: outputScale,
        tileScale: tileScale
    });
    
    var mu1 = ee.Number(cottonCSP.aggregate_mean(bandName));
    var delta1 = ee.Number(cottonCSP.aggregate_total_sd(bandName)).max(0.0001);
    var mu2 = ee.Number(otherCSP.aggregate_mean(bandName));
    var delta2 = ee.Number(otherCSP.aggregate_total_sd(bandName)).max(0.0001);
    
    var M_index = mu1.subtract(mu2).abs().divide(delta1.add(delta2));
    
    var delta1Sq = delta1.pow(2);
    var delta2Sq = delta2.pow(2);
    
    var B_term1 = mu1.subtract(mu2).pow(2)
        .multiply(0.125).multiply(2)
        .divide(delta1Sq.add(delta2Sq));
    
    var B_term2 = delta1Sq.add(delta2Sq)
        .divide(delta1.multiply(delta2).multiply(2))
        .log().multiply(0.5);
    
    var B = B_term1.add(B_term2);
    
    var JM_index = ee.Number(2).multiply(
        ee.Number(1).subtract(B.multiply(-1).exp())
    );
    
    return {M: M_index, JM: JM_index};
}



// ── 字符串填充（GEE JS 没有 String.padStart/padEnd） ──
function padRight(str, len) {
    str = String(str);
    while (str.length < len) str += ' ';
    return str;
}
function padLeft(str, len) {
    str = String(str);
    while (str.length < len) str = ' ' + str;
    return str;
}

// ── 创建零数组（替代 new Array(n).fill(0)，GEE不支持fill） ──
function zeroArray(n) {
    var arr = [];
    for (var i = 0; i < n; i++) arr.push(0);
    return arr;
}


