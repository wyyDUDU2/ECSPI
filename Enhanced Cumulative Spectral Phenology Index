// ===== Section 22: 替换 m4Step2Btn.onClick =====
m4Step2Btn.onClick(function() {
    if (!globalCache.CSP_fused || !globalCache.s2WithAllIndices) {
        m4Status.setValue('ERROR: Run Step 4.1 first and ensure base data loaded!');
        return;
    }
    
    if (m4_ndviStats) {
        m4Status.setValue('S2 NDVI features cached, verifying...');
        m4_ndviStats.bandNames().evaluate(function(bands, error) {
            if (error) { m4_ndviStats = null; m4Status.setValue('Cache invalid'); return; }
            m4Status.setValue('S2 NDVI features cached (' + bands.length + ' bands)');
            globalStatusLabel.setValue('M4 Step 2: Using cache');
        });
        return;
    }
    
    m4Status.setValue('Computing S2 NDVI stats + phenology (extendedMask)...');
    globalStatusLabel.setValue('M4: S2 NDVI features with extendedMask...');
    
    var startDateEE = globalCache.startDateEE;
    var periodSeq = globalCache.periodSeq;
    
    // 构建 S2 NDVI 复合影像（不带掩膜，原始数据）
    var s2NDVIComposites = ee.ImageCollection.fromImages(
        periodSeq.map(function(periodIndex) {
            periodIndex = ee.Number(periodIndex);
            var periodStart = startDateEE.advance(periodIndex.multiply(compositePeriod), 'day');
            var periodEnd = periodStart.advance(compositePeriod, 'day');
            var midDate = periodStart.advance(compositePeriod / 2, 'day');
            var doy = midDate.getRelative('day', 'year');
            
            var periodImages = globalCache.s2WithAllIndices
                .filterDate(periodStart, periodEnd)
                .select('NDVI');
            
            var composite = ee.Algorithms.If(
                periodImages.size().gt(0),
                periodImages.median().float(),
                ee.Image.constant(0).float().rename('NDVI')
                    .updateMask(ee.Image.constant(0))
            );
            
            return ee.Image(composite).float()
                .set('system:time_start', midDate.millis())
                .set('DOY', doy)
                .set('period_index', periodIndex);
        })
    );
    
    // Part A: 时序统计 (4 bands) — 不需要掩膜，reducer 自动跳过 nodata
    var s2NDVITemporalStats = s2NDVIComposites.select('NDVI').reduce(
        ee.Reducer.mean()
            .combine(ee.Reducer.min(), null, true)
            .combine(ee.Reducer.max(), null, true)
            .combine(ee.Reducer.stdDev(), null, true)
    ).rename(['NDVI_S2_mean', 'NDVI_S2_min', 'NDVI_S2_max', 'NDVI_S2_stdDev'])
     .float().clip(studyArea);
    
    // Part B: 物候特征 — 使用 extendedMask（关键修改！）
    m4Status.setValue('Extracting S2 NDVI phenology (extendedMask)...');
    var ndviPheno = extractIndexPhenology(
        s2NDVIComposites, 'NDVI', globalCache.doyList,
        extendedMask,   // ← 关键修改：原来是 comprehensiveMask
        'NDVI_S2', false
    );
    
    // 从 phenology 只保留 valT1, valT2, rate（去掉 T1, T2, amp, dur）
    var ndviPhenoFiltered = ndviPheno.select([
        'NDVI_S2_valT1', 'NDVI_S2_valT2', 'NDVI_S2_rate'
    ]);
    
    // 合并: 4 stats + 3 filtered phenology = 7 bands
    var combinedNDVI = ee.Image.cat([s2NDVITemporalStats, ndviPhenoFiltered])
        .float().clip(studyArea);
    
    combinedNDVI.bandNames().evaluate(function(bands, error) {
        if (error) {
            m4Status.setValue('ERROR: S2 NDVI features failed - ' + error);
