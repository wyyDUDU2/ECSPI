// ║  SECTION 14 : PER-CATEGORY ACCURACY EVALUATION FUNCTION                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

function perCategoryAccuracy(classImage, cottonFC, otherFC) {
    var cottonTest = cottonFC.filter(ee.Filter.eq('split', 'test'));
    var otherTest  = otherFC.filter(ee.Filter.eq('split', 'test'));
    var allTest    = cottonTest.merge(otherTest);

    var predicted = classImage.unmask(0).rename('predicted');

    var testWithPred = predicted.sampleRegions({
        collection: allTest,
        properties: ['class', 'cropType', 'cropName', 'split'],
        scale: 10,
        tileScale: 16
    });

    var overallCM = testWithPred.errorMatrix('class', 'predicted');
    print('');
    print('╔══════════════════════════════════════════════════════════╗');
    print('║  OVERALL ACCURACY (spatial-block test set)               ║');
    print('╚══════════════════════════════════════════════════════════╝');
    print('Confusion matrix:', overallCM);
    print('OA:',    overallCM.accuracy());
    print('Kappa:', overallCM.kappa());

    var arr = overallCM.array();
    var tp  = arr.get([1, 1]);
    var fp  = arr.get([0, 1]);
    var fn  = arr.get([1, 0]);
    var tn  = arr.get([0, 0]);
    var precision = ee.Number(tp).divide(ee.Number(tp).add(fp).max(1));
    var recall    = ee.Number(tp).divide(ee.Number(tp).add(fn).max(1));
    var f1 = ee.Number(2).multiply(precision).multiply(recall)
        .divide(precision.add(recall).max(0.0001));
    print('Precision (UA):', precision);
    print('Recall (PA):',    recall);
    print('F1:',             f1);
    print('TP:', tp, ' FP:', fp, ' FN:', fn, ' TN:', tn);

    var subCategories = [
        {name: 'Corn',      value: 2},
        {name: 'Wheat',     value: 3},
        {name: 'Orchard',   value: 4},
        {name: 'OtherCrop', value: 5},
        {name: 'NonCrop',   value: 6}
    ];

    print('');
    print('╔══════════════════════════════════════════════════════════╗');
    print('║  PER-CATEGORY: Cotton vs specific non-cotton class       ║');
    print('╚══════════════════════════════════════════════════════════╝');

    subCategories.forEach(function(cat) {
        var catTestPts    = testWithPred.filter(ee.Filter.eq('cropType', cat.value));
        var cottonTestPts = testWithPred.filter(ee.Filter.eq('class', 1));
        var subset        = cottonTestPts.merge(catTestPts);

        var nCatTest = catTestPts.size();
        var nCotTest = cottonTestPts.size();

        var subCM = subset.errorMatrix('class', 'predicted');
        print('');
        print('─── Cotton vs ' + cat.name + ' ───');
        print('  n(cotton test):', nCotTest, '  n(' + cat.name + ' test):', nCatTest);
        print('  Confusion matrix:', subCM);
        print('  OA:', subCM.accuracy());
        print('  Kappa:', subCM.kappa());

        var subArr   = subCM.array();
        var sub_tp   = subArr.get([1, 1]);
        var sub_fp   = subArr.get([0, 1]);
        var sub_fn   = subArr.get([1, 0]);
        var sub_tn   = subArr.get([0, 0]);
        var sub_prec = ee.Number(sub_tp).divide(ee.Number(sub_tp).add(sub_fp).max(1));
        var sub_rec  = ee.Number(sub_tp).divide(ee.Number(sub_tp).add(sub_fn).max(1));
        var sub_f1   = ee.Number(2).multiply(sub_prec).multiply(sub_rec)
            .divide(sub_prec.add(sub_rec).max(0.0001));
        print('  Precision:', sub_prec);
        print('  Recall:',    sub_rec);
        print('  F1:',        sub_f1);
    });

    return testWithPred;
}

